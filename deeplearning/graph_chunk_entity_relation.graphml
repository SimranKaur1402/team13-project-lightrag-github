    <node id="Software Engineers">
      <data key="d0">Software Engineers</data>
      <data key="d1">group</data>
      <data key="d2">Software engineers without a machine learning background are also a primary target audience, aiming to acquire knowledge rapidly in order to utilize deep learning in products or platforms.</data>
      <data key="d3">chunk-bd2a057016fddbfc53fb1a5ab4973351</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768911163</data>
