    </node>
    <node id="Laser Photocoagulation">
      <data key="d0">Laser Photocoagulation</data>
      <data key="d1">method</data>
      <data key="d2">Laser photocoagulation is a medical procedure used to treat severe cases of retinopathy by using a laser to prevent vision loss.&lt;SEP&gt;Laser photocoagulation is a treatment method used in retinopathy that has effectively reduced diabetes-related blindness.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b&lt;SEP&gt;chunk-c4d75b2c01d2448f37de4deec12208fa</data>
      <data key="d4">unknown_source</data>
