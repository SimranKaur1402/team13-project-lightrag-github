    <node id="Perceptron">
      <data key="d0">Perceptron</data>
      <data key="d1">method</data>
      <data key="d2">The Perceptron is a machine learning model introduced by Rosenblatt in 1958, capable of learning weights that define input categories based on training examples.</data>
      <data key="d3">chunk-5f255acea8c3a7b10af84028b23d7ead</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768911153</data>
