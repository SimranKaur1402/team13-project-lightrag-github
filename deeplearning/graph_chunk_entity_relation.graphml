    <node id="Acarbose">
      <data key="d0">Acarbose</data>
      <data key="d1">method</data>
      <data key="d2">Acarbose is an α-glucosidase inhibitor that delays carbohydrate absorption, used to manage diabetes.&lt;SEP&gt;Acarbose is an α-glucosidase inhibitor taken in doses of 100–300 mg/day to delay carbohydrate absorption.</data>
      <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063&lt;SEP&gt;chunk-453e4228f98ddea76e07ce405d13fd32</data>
