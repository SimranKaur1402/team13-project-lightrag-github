    <node id="Photocoagulation">
      <data key="d0">Photocoagulation</data>
      <data key="d1">method</data>
      <data key="d2">Photocoagulation is a method used in laser therapy to treat eye complications associated with diabetes, particularly retinopathy.&lt;SEP&gt;Photocoagulation is a treatment method used to manage retinopathy by targeting the retinal tissue with lasers.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
