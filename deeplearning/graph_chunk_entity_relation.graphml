    <node id="Hidden Layers">
      <data key="d0">Hidden Layers</data>
      <data key="d1">concept</data>
      <data key="d2">Hidden layers are intermediary layers in a neural network that extract features from input data, not directly observed but constructed through learning.</data>
      <data key="d3">chunk-ec8cde6747414a42b9f90501d7dd0d2a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768911165</data>
