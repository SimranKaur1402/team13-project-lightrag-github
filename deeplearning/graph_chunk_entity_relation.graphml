      <data key="d0">Casual Blood Glucose Measurement</data>
      <data key="d1">method</data>
      <data key="d2">Casual Blood Glucose Measurement assesses blood glucose levels at any time of day and is indicative of diabetes when certain thresholds are met.</data>
      <data key="d3">chunk-25fb88c8ed14936954356d104de095d4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768915083</data>
