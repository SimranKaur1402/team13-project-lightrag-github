    <node id="Type 1 Diabetes">
      <data key="d0">Type 1 Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Type 1 diabetes is an autoimmune condition characterized by the body's inability to produce insulin, often leading to ketoacidosis.&lt;SEP&gt;Type 1 diabetes is a form of diabetes requiring early detection and monitoring for complications such as retinopathy and nephropathy.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
