      <data key="d0">Poly-Unsaturated Fatty Acids</data>
      <data key="d1">concept</data>
      <data key="d2">Poly-unsaturated fatty acids are known to decrease plasma total and LDL cholesterol when compared to saturated fatty acids.</data>
      <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768915076</data>
