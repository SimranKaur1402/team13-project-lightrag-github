      <data key="d1">concept</data>
      <data key="d2">Diabetic foot describes conditions arising in the feet due to diabetes, including complications like infection and ulceration.</data>
      <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768915086</data>
