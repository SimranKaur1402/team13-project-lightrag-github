      <data key="d0">Pioglitazone</data>
      <data key="d1">method</data>
      <data key="d2">Pioglitazone is another thiazolidinedione that similarly increases insulin sensitivity and decreases hepatic glucose production.</data>
      <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
