      <data key="d0">Lipid Abnormalities</data>
      <data key="d1">concept</data>
      <data key="d2">Lipid abnormalities refer to conditions affecting lipid levels in the blood, which may be significant in managing diabetes and preventing nephropathy.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768915082</data>
