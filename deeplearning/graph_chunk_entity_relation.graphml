    <node id="Primary Prevention">
      <data key="d0">Primary Prevention</data>
      <data key="d1">concept</data>
      <data key="d2">Primary prevention focuses on preventing the onset of type 2 diabetes through lifestyle modifications and education.&lt;SEP&gt;Primary prevention focuses on preventing the onset of diabetes and reducing the need for further diabetes care.</data>
