    <node id="Metformin">
      <data key="d0">Metformin</data>
      <data key="d1">method</data>
      <data key="d2">Metformin is a biguanide that decreases hepatic glucose production and increases insulin sensitivity, used in treating diabetes.&lt;SEP&gt;Metformin is an oral medication preferred for treating type 2 diabetes.</data>
      <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063&lt;SEP&gt;chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768915076</data>
      <data key="d6" />
    </node>
    <node id="Rosiglitazone">
      <data key="d0">Rosiglitazone</data>
      <data key="d1">method</data>
      <data key="d2">Rosiglitazone is a thiazolidinedione that increases insulin sensitivity and decreases hepatic glucose production, used in diabetes management.</data>
      <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768915076</data>
