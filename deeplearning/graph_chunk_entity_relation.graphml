    <node id="Eigenvectors">
      <data key="d0">Eigenvectors</data>
      <data key="d1">concept</data>
      <data key="d2">Eigenvectors are non-zero vectors that only stretch or compress when a linear transformation is applied, without changing their direction.</data>
