    <node id="Contrastive Divergence">
      <data key="d0">Contrastive Divergence</data>
      <data key="d1">method</data>
      <data key="d2">Contrastive Divergence is a technique used for training certain types of probabilistic models by approximating gradients with shorter Markov chains.</data>
      <data key="d3">chunk-e50469f832851b636f2df3ba1727f237</data>
      <data key="d4">unknown_source</data>
