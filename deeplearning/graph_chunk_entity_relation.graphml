    <node id="National Strategy for Diabetes Management">
      <data key="d0">National Strategy for Diabetes Management</data>
      <data key="d1">concept</data>
      <data key="d2">A national strategy for diabetes management entails systematic approaches to monitoring and controlling diabetes and its related conditions.</data>
