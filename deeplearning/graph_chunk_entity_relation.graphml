    <node id="Trans-Fatty Acids">
      <data key="d0">Trans-Fatty Acids</data>
      <data key="d1">concept</data>
      <data key="d2">Trans-fatty acids are recognized for raising plasma LDL cholesterol and lowering plasma HDL cholesterol, leading to recommendations for minimized intake.</data>
      <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
