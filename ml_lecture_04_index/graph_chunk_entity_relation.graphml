    <node id="Probability Mass Function">
      <data key="d0">Probability Mass Function</data>
      <data key="d1">concept</data>
      <data key="d2">The probability mass function describes the probability distribution for discrete random variables, particularly mentioned in relation to Y equals zero or one during the lecture.</data>
