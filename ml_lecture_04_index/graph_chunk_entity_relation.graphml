    <node id="Training Set">
      <data key="d0">Training Set</data>
      <data key="d1">data</data>
      <data key="d2">The training set consists of data used for parameter optimization in maximum likelihood estimation.&lt;SEP&gt;The training set consists of input-output pairs used to train machine learning models.</data>
      <data key="d3">chunk-674af09a64beddbff4e4e4b6e543709a&lt;SEP&gt;chunk-ac0a1ea80eae7c222bf0ffd73875b023</data>
