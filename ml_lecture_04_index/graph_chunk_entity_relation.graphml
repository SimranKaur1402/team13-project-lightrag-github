    <node id="Softmax Regression">
      <data key="d0">Softmax Regression</data>
      <data key="d1">method</data>
      <data key="d2">Softmax regression is a machine learning algorithm used for modeling probabilities of K classes, generalizing logistic regression.</data>
      <data key="d3">chunk-674af09a64beddbff4e4e4b6e543709a</data>
