    <node id="Phi One">
      <data key="d0">Phi One</data>
      <data key="d1">concept</data>
      <data key="d2">Phi One is a shorthand notation representing a formula that depends on theta in the context of a statistical model.</data>
      <data key="d3">chunk-ac0a1ea80eae7c222bf0ffd73875b023</data>
