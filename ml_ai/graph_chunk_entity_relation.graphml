    <node id="X">
      <data key="d0">X</data>
      <data key="d1">data</data>
      <data key="d2">X represents the independent variables used in models for predicting the dependent variable PFY.&lt;SEP&gt;X refers to the input data features in the machine learning problem associated with softmax regression.</data>
      <data key="d3">chunk-674af09a64beddbff4e4e4b6e543709a&lt;SEP&gt;chunk-1aa4c1f1bcccecc7faef4f12ad096763</data>
