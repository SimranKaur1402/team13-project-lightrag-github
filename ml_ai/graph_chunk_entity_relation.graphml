  <graph edgedefault="undirected">
    <node id="Andrew Ng">
      <data key="d0">Andrew Ng</data>
      <data key="d1">person</data>
      <data key="d2">Andrew Ng is an instructor discussing algorithms related to logistic regression and Newton's Method in the context of a classroom setting.&lt;SEP&gt;Andrew Ng is the instructor for the Machine Learning course who provides administrative announcements regarding class projects and materials.&lt;SEP&gt;Andrew Ng is an instructor who discusses mathematical and statistical concepts in the context of statistics and probability.&lt;SEP&gt;Andrew Ng is an instructor who is guiding students through concepts in a lecture, including scalers and distributions.&lt;SEP&gt;Andrew Ng is an instructor discussing logistic regression and generalized linear models in a lecture setting.&lt;SEP&gt;Andrew Ng is an instructor involved in a discussion about maximum likelihood and logistic regression principles.</data>
      <data key="d3">chunk-023cc775f8b1adeebc9c45d2e9f6fe90&lt;SEP&gt;chunk-ac0a1ea80eae7c222bf0ffd73875b023&lt;SEP&gt;chunk-1dcfa4fdc2012c4e3a3c336e39e4afec&lt;SEP&gt;chunk-e92ae48716b56f03feed3a2648edf8bd&lt;SEP&gt;chunk-1aa4c1f1bcccecc7faef4f12ad096763&lt;SEP&gt;chunk-d65cfad802d1335db113217e2cb6afbe</data>
      <data key="d4">unknown_source</data>
