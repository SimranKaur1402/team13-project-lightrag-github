    </node>
    <node id="Natural Parameter">
      <data key="d0">Natural Parameter</data>
      <data key="d1">concept</data>
      <data key="d2">The natural parameter is a specific parameterization of a distribution that simplifies the form of the probability functions in exponential family distributions.</data>
      <data key="d3">chunk-38d7cccd02d2282bbd339ef51ba43f85</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767942412</data>
