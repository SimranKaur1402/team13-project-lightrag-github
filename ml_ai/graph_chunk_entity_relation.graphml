    <node id="Training Set">
      <data key="d0">Training Set</data>
      <data key="d1">data</data>
      <data key="d2">The Training Set consists of input-output pairs (X, Y) used to estimate the parameters of the model through maximum likelihood.&lt;SEP&gt;The training set consists of data points used to estimate the parameters of the model through likelihood optimization.</data>
      <data key="d3">chunk-ac0a1ea80eae7c222bf0ffd73875b023&lt;SEP&gt;chunk-674af09a64beddbff4e4e4b6e543709a</data>
