<node id="Low-Power Wide-Area Network (LoRaWAN)">
  <data key="d0">Low-Power Wide-Area Network (LoRaWAN)</data>
  <data key="d1">protocol</data>
  <data key="d2">LoRaWAN is a communication protocol that enables connectivity among devices through a star topology and supports various IoT applications.</data>
  <data key="d3">chunk-11a8a4925599d83f5b5063a2bdbd9aa6</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769582103</data>
  <data key="d6"></data>
</node>
<node id="User Datagram Protocol (UDP)">
  <data key="d0">User Datagram Protocol (UDP)</data>
  <data key="d1">protocol</data>
  <data key="d2">UDP is a primary transport layer protocol that operates on the RST architecture, known for its simple header-only format.</data>
  <data key="d3">chunk-11a8a4925599d83f5b5063a2bdbd9aa6</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769582103</data>
