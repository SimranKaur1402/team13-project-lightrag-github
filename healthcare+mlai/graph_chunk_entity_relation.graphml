<node id="Factors of Variation">
  <data key="d0">Factors of Variation</data>
  <data key="d1">concept</data>
  <data key="d2">Factors of variation are sources of influence that explain the observed data and may not be directly observable.</data>
  <data key="d3">chunk-d052846d3bce5d76b5380e3fe4a4925e</data>
  <data key="d4">unknown_source</data>
