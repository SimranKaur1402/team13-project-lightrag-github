  <data key="d0">Cyc</data>
  <data key="d1">organization</data>
  <data key="d2">Cyc is a well-known artificial intelligence project that functions as an inference engine and a database of statements in a formal language called CycL, managed by human supervisors.</data>
  <data key="d3">chunk-010a987a088000cbaebd51b9889052f3</data>
  <data key="d4">unknown_source</data>
