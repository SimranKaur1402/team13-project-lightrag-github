  <data key="d0">World Health Organization (WHO)</data>
  <data key="d1">organization</data>
  <data key="d2">The World Health Organization sets criteria for the classification of diabetes mellitus and gestational diabetes.</data>
  <data key="d3">chunk-12fe828372a20b6606e010f0fd5e6263</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Acute Complications of Diabetes Mellitus">
  <data key="d0">Acute Complications of Diabetes Mellitus</data>
  <data key="d1">event</data>
  <data key="d2">Acute complications of diabetes mellitus encompass a range of health issues that arise suddenly and can have severe consequences, including infections and ketoacidosis.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Tuberculosis">
  <data key="d0">Tuberculosis</data>
  <data key="d1">disease</data>
  <data key="d2">Tuberculosis is a bacterial infection that poses serious health threats to individuals with diabetes, affecting various organ systems.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Fungal Infections">
  <data key="d0">Fungal Infections</data>
  <data key="d1">disease</data>
  <data key="d2">Fungal infections, particularly in diabetic patients, are significant health threats and can complicate existing health conditions.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Bacterial Infections">
  <data key="d0">Bacterial Infections</data>
  <data key="d1">disease</data>
  <data key="d2">Bacterial infections, especially urinary tract infections, are more prevalent in individuals with diabetes and can lead to severe health issues if not treated.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Neurogenic Bladder">
  <data key="d0">Neurogenic Bladder</data>
  <data key="d1">condition</data>
  <data key="d2">Neurogenic bladder is a condition that can lead to urinary tract infections in diabetic individuals due to impaired bladder function.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Pyelitis">
  <data key="d0">Pyelitis</data>
  <data key="d1">disease</data>
  <data key="d2">Pyelitis is an infection of the kidney that can worsen diabetic nephropathy and is a concern for diabetic patients.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Pyelonephritis">
  <data key="d0">Pyelonephritis</data>
  <data key="d1">disease</data>
  <data key="d2">Pyelonephritis is a severe kidney infection that can exacerbate complications in individuals with diabetes.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Atherosclerosis">
  <data key="d0">Atherosclerosis</data>
  <data key="d1">disease</data>
  <data key="d2">Atherosclerosis is the most common macrovascular complication of diabetes, significantly increasing the risk of cardiovascular events.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Retinopathy">
  <data key="d0">Retinopathy</data>
  <data key="d1">concept</data>
  <data key="d2">Diabetic retinopathy is a leading cause of blindness in adults with diabetes, often developing severe forms over time.&lt;SEP&gt;Retinopathy is a sight-threatening condition that can lead to blindness and often asymptomatic, making awareness and detection crucial.&lt;SEP&gt;Retinopathy refers to eye diseases resulting from diabetes, leading to vision impairment and is a significant concern during pregnancy for women with diabetes.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-7ef79f22f40772c2060b439008ce485b&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Macular Oedema">
  <data key="d0">Macular Oedema</data>
  <data key="d1">condition</data>
  <data key="d2">Macular oedema is a sight-threatening complication related to diabetic retinopathy affecting the central part of the retina.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Hyperinsulinaemia">
  <data key="d0">Hyperinsulinaemia</data>
  <data key="d1">condition</data>
  <data key="d2">Hyperinsulinaemia is a condition of elevated insulin levels in the blood, linked to increased risk of coronary disease in individuals with diabetes.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Pakistan">
  <data key="d0">Pakistan</data>
  <data key="d1">location</data>
  <data key="d2">Pakistan has a diabetes prevalence rate of 11% despite being less affluent than its neighboring countries.</data>
  <data key="d3">chunk-f15f59b3ff05825a61f252ed8f9a74e1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
  <data key="d6"></data>
</node>
<node id="Bahrain (Country)">
  <data key="d0">Bahrain (Country)</data>
  <data key="d1">location</data>
  <data key="d2">Bahrain is a country in the Eastern Mediterranean Region with high diabetes prevalence and varying capacity for healthcare services.</data>
  <data key="d3">chunk-f15f59b3ff05825a61f252ed8f9a74e1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
