<node id="HbA1c">
  <data key="d0">HbA1c</data>
  <data key="d1">data</data>
  <data key="d2">HbA1c is a blood test that provides information about a person's average levels of blood glucose over the past 3 months and is crucial for diabetes management.&lt;SEP&gt;HbA1c is a blood test that measures average blood glucose levels over the past two to three months and is important for diabetes management.&lt;SEP&gt;HbA1c is a blood test that measures average blood glucose levels over time and is crucial for monitoring diabetes control.</data>
  <data key="d3">chunk-e5fc5e661d0f94cc23c0188b9bbe4e08&lt;SEP&gt;chunk-eb1bc7614fcd68decf9461b3b6290e95&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
