  <data key="d5">1770136344</data>
  <data key="d6"></data>
</node>
<node id="Diabetes Mortality">
  <data key="d0">Diabetes Mortality</data>
  <data key="d1">concept</data>
  <data key="d2">Diabetes mortality refers to the death rate associated with diabetes, significantly influenced by cardiovascular complications.</data>
  <data key="d3">chunk-e8e236a5eba0e1dbf843d32e509da045</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136345</data>
  <data key="d6"></data>
</node>
<node id="Neuropathy">
  <data key="d0">Neuropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Neuropathy refers to nerve damage that can occur with diabetes, affecting both the limbs and internal organs.</data>
