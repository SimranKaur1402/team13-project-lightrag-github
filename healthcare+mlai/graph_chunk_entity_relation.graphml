  <data key="d0">Oral Hypoglycaemic Agents</data>
  <data key="d1">method</data>
  <data key="d2">Oral Hypoglycaemic Agents are medications used to help control blood glucose levels in type 2 diabetes patients.&lt;SEP&gt;Oral hypoglycaemic agents are medications taken by mouth to lower blood glucose levels in individuals with diabetes.</data>
  <data key="d3">chunk-a560aca3f99b145384c2b736c2ceea1c&lt;SEP&gt;chunk-ed87909b4bdb657354ca0eab1450156f</data>
