  <data key="d4">unknown_source</data>
  <data key="d5">1770136344</data>
  <data key="d6"></data>
</node>
<node id="Cardiovascular Disease Risk">
  <data key="d0">Cardiovascular Disease Risk</data>
  <data key="d1">concept</data>
  <data key="d2">Cardiovascular disease risk refers to the likelihood of developing cardiovascular conditions, influenced by factors such as hyperglycaemia and metabolic syndrome.</data>
