</node>
<node id="Macrovascular Complications">
  <data key="d0">Macrovascular Complications</data>
  <data key="d1">concept</data>
  <data key="d2">Macrovascular complications refer to cardiovascular issues that can develop due to elevated fasting glucose levels.</data>
