<node id="Microalbuminuria">
  <data key="d0">Microalbuminuria</data>
  <data key="d1">concept</data>
  <data key="d2">Microalbuminuria is a condition characterized by an elevated level of albumin in urine, which is an early indicator of diabetic nephropathy.</data>
  <data key="d3">chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136344</data>
  <data key="d6"></data>
</node>
<node id="Diabetic Retinopathy">
  <data key="d0">Diabetic Retinopathy</data>
  <data key="d1">concept</data>
  <data key="d2">Diabetic Retinopathy is a specific type of retinopathy that occurs in individuals with diabetes and can lead to vision loss without early detection and treatment.</data>
  <data key="d3">chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136344</data>
  <data key="d6"></data>
</node>
<node id="Kidney Disease">
  <data key="d0">Kidney Disease</data>
  <data key="d1">concept</data>
  <data key="d2">Kidney Disease is a general term for health conditions that affect the kidneys, including diabetic nephropathy as a specific type.</data>
  <data key="d3">chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136344</data>
  <data key="d6"></data>
</node>
<node id="Laser Technology">
  <data key="d0">Laser Technology</data>
  <data key="d1">method</data>
  <data key="d2">Laser Technology is equipment used in the treatment of retinopathy and other conditions requiring precise surgical intervention.</data>
