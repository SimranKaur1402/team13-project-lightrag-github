</node>
<node id="Renal Damage">
  <data key="d0">Renal Damage</data>
  <data key="d1">concept</data>
  <data key="d2">Renal Damage refers to any injury to the kidneys that can progress to more severe conditions, often related to diabetes and hypertension.</data>
