  <data key="d0">Colestipol</data>
  <data key="d1">drug</data>
  <data key="d2">Colestipol is another bile acid sequestrant with a dose range of 5–20 g, aimed at managing cholesterol levels.</data>
  <data key="d3">chunk-21112bd6ed1fe7896dbf55a52bc45a2d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578521</data>
