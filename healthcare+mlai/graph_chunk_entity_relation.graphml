  <data key="d0">Klinefelter Syndrome</data>
  <data key="d1">concept</data>
  <data key="d2">Klinefelter syndrome is a rare genetic condition associated with diabetes.</data>
  <data key="d3">chunk-12fe828372a20b6606e010f0fd5e6263</data>
  <data key="d4">unknown_source</data>
