<node id="Ophthalmologist">
  <data key="d0">Ophthalmologist</data>
  <data key="d1">person</data>
  <data key="d2">The ophthalmologist conducts annual retinal screenings for diabetes patients to monitor eye health and complications.&lt;SEP&gt;An ophthalmologist is a medical doctor specializing in eye care, recommended for proper screening and treatment of diabetic retinopathy.</data>
  <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b&lt;SEP&gt;chunk-a560aca3f99b145384c2b736c2ceea1c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
  <data key="d6"></data>
</node>
<node id="Primary Care Physician">
  <data key="d0">Primary Care Physician</data>
  <data key="d1">person</data>
  <data key="d2">A primary care physician is a healthcare provider responsible for managing the general health of patients, including screening for diabetic retinopathy when ophthalmologists are unavailable.</data>
  <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
  <data key="d6"></data>
</node>
<node id="Photocoagulation">
  <data key="d0">Photocoagulation</data>
  <data key="d1">method</data>
  <data key="d2">Photocoagulation is a treatment method for retinopathy involving the use of lasers to prevent vision loss.&lt;SEP&gt;Photocoagulation is a medical procedure using lasers to treat retinal issues associated with diabetic retinopathy.</data>
  <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
  <data key="d6"></data>
</node>
<node id="Clinical Trials">
  <data key="d0">Clinical Trials</data>
  <data key="d1">event</data>
  <data key="d2">Clinical trials are research studies that assess the efficacy of treatments like laser photocoagulation for managing diabetic retinopathy.</data>
  <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
  <data key="d6"></data>
</node>
<node id="Laser Equipment">
  <data key="d0">Laser Equipment</data>
  <data key="d1">equipment</data>
  <data key="d2">Laser equipment is the technology necessary for treating retinopathy through procedures such as photocoagulation.&lt;SEP&gt;Laser equipment is necessary for treating diabetic retinopathy through procedures like photocoagulation.</data>
  <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
  <data key="d6"></data>
</node>
<node id="Vision-Threatening Retinopathy">
  <data key="d0">Vision-Threatening Retinopathy</data>
  <data key="d1">concept</data>
  <data key="d2">Vision-threatening retinopathy is a severe form of diabetic retinopathy that can lead to vision loss if not treated properly.</data>
  <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578533</data>
  <data key="d6"></data>
</node>
