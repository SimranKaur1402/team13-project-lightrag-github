<node id="IFG">
  <data key="d0">IFG</data>
  <data key="d1">concept</data>
  <data key="d2">IFG, or Impaired Fasting Glucose, refers to a fasting plasma glucose concentration of 6.1 to 7.0 mmol/L, indicating a risk for diabetes.</data>
  <data key="d3">chunk-42a410eaaaed4b7428f5e95a4c7c4580</data>
  <data key="d4">unknown_source</data>
