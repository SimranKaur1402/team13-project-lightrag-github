<node id="Atherosclerosis">
  <data key="d0">Atherosclerosis</data>
  <data key="d1">concept</data>
  <data key="d2">Atherosclerosis is the most common macrovascular complication of diabetes, associated with increased mortality and morbidity rates.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
