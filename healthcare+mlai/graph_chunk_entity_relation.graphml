<node id="Ophthalmoscopy">
  <data key="d0">Ophthalmoscopy</data>
  <data key="d1">method</data>
  <data key="d2">Ophthalmoscopy is a diagnostic procedure that enables examination of the retina, important for the detection of retinopathy.</data>
