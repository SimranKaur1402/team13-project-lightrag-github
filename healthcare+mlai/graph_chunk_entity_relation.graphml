  <data key="d0">Hypoglycaemia Unawareness</data>
  <data key="d1">condition</data>
  <data key="d2">Hypoglycaemia unawareness is a condition in which patients fail to recognize the symptoms of low blood sugar, increasing their risk for severe episodes.</data>
  <data key="d3">chunk-ed87909b4bdb657354ca0eab1450156f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136332</data>
