<node id="Plasma Glucose">
  <data key="d0">Plasma Glucose</data>
  <data key="d1">data</data>
  <data key="d2">Plasma glucose refers to the measurement of glucose levels in the blood, typically used for laboratory assessments in diabetes management.</data>
  <data key="d3">chunk-e5fc5e661d0f94cc23c0188b9bbe4e08</data>
  <data key="d4">unknown_source</data>
