<node id="Oussama MN Khatib">
  <data key="d0">Oussama MN Khatib</data>
  <data key="d1">person</data>
  <data key="d2">Oussama MN Khatib is the editor of the guidelines and holds an MD, PhD, and FRCP, serving as a Regional Adviser for noncommunicable diseases.</data>
  <data key="d3">chunk-b253411e54c35aa95f5f9179723bba3b</data>
  <data key="d4">unknown_source</data>
