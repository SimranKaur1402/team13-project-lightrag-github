  <data key="d6"></data>
</node>
<node id="L∞ Norm">
  <data key="d0">L∞ Norm</data>
  <data key="d1">concept</data>
  <data key="d2">The L∞ norm is a mathematical measure that considers the maximum absolute value among the components of a vector.&lt;SEP&gt;The L∞ Norm measures the largest absolute value in a vector, representing its maximum magnitude.</data>
  <data key="d3">chunk-0403607cb7181d4a13a232d13fec9630&lt;SEP&gt;chunk-e325d64a50359748cfb47987a361fbb1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136821</data>
