<node id="Taiwan">
  <data key="d0">Taiwan</data>
  <data key="d1">location</data>
  <data key="d2">Taiwan is referenced as the location for a study showing type 2 diabetes as the leading cause of diabetes in children aged 6–18 years.</data>
  <data key="d3">chunk-12fe828372a20b6606e010f0fd5e6263</data>
  <data key="d4">unknown_source</data>
