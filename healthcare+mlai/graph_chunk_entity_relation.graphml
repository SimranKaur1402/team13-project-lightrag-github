  <data key="d0">Finland Study by Tuomilehto</data>
  <data key="d1">event</data>
  <data key="d2">The Finland Study by Tuomilehto investigated the impact of exercise and diet modifications on the incidence of type 2 diabetes in individuals with IGT.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136324</data>
  <data key="d6"></data>
</node>
<node id="Diabetes Prevention Programme Research Group">
  <data key="d0">Diabetes Prevention Programme Research Group</data>
  <data key="d1">organization</data>
  <data key="d2">The Diabetes Prevention Programme Research Group conducted a study to assess lifestyle modifications in reducing the risk of type 2 diabetes among non-diabetic individuals.&lt;SEP&gt;The Diabetes Prevention Programme Research Group focuses on researching the impact of lifestyle modification and medication on diabetes incidence.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa&lt;SEP&gt;chunk-942e000d0de99e8628ab9c8bcbe83419</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136324</data>
  <data key="d6"></data>
</node>
<node id="Eastern Mediterranean Countries">
  <data key="d0">Eastern Mediterranean Countries</data>
  <data key="d1">location</data>
  <data key="d2">Eastern Mediterranean countries are regions suggested to prioritize community-based healthy lifestyle programs to prevent type 2 diabetes.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136324</data>
  <data key="d6"></data>
</node>
<node id="Type 1 Diabetes">
  <data key="d0">Type 1 Diabetes</data>
  <data key="d1">concept</data>
  <data key="d2">Type 1 diabetes is an autoimmune condition leading to insulin deficiency, commonly diagnosed in children, with varying incidences in the Eastern Mediterranean.&lt;SEP&gt;Type 1 diabetes is a form of diabetes mellitus characterized by the autoimmune destruction of insulin-producing cells in the pancreas.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa&lt;SEP&gt;chunk-d8c827cc2249067692290d6a8a0e8018</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136324</data>
  <data key="d6"></data>
</node>
<node id="International Diabetes Federation">
  <data key="d0">International Diabetes Federation</data>
  <data key="d1">organization</data>
  <data key="d2">The International Diabetes Federation is a global organization that aims to improve the lives of people with diabetes through advocacy and education.&lt;SEP&gt;The International Diabetes Federation is an organization that focuses on advocating for diabetes care, prevention, and research globally.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa&lt;SEP&gt;chunk-942e000d0de99e8628ab9c8bcbe83419</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136324</data>
  <data key="d6"></data>
</node>
<node id="Weight Maintenance">
  <data key="d0">Weight Maintenance</data>
  <data key="d1">concept</data>
  <data key="d2">Weight maintenance refers to the practice of managing body weight within a healthy range, which is crucial for preventing type 2 diabetes.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136324</data>
  <data key="d6"></data>
</node>
<node id="Healthy Lifestyle Programmes">
  <data key="d0">Healthy Lifestyle Programmes</data>
  <data key="d1">concept</data>
  <data key="d2">Healthy lifestyle programmes aim to promote physical activity and balanced diets to reduce the risk of chronic diseases, including diabetes.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136325</data>
  <data key="d6"></data>
</node>
<node id="Secondary Prevention">
  <data key="d0">Secondary Prevention</data>
  <data key="d1">concept</data>
  <data key="d2">Secondary prevention consists of strategies aimed at early detection and management of diseases in individuals already affected, to prevent complications.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136325</data>
