</node>
<node id="IFG">
  <data key="d0">IFG</data>
  <data key="d1">concept</data>
  <data key="d2">IFG (Impaired Fasting Glucose) is a metabolic condition characterized by elevated fasting plasma glucose levels, indicating potential risk for diabetes.</data>
  <data key="d3">chunk-42a410eaaaed4b7428f5e95a4c7c4580</data>
  <data key="d4">unknown_source</data>
