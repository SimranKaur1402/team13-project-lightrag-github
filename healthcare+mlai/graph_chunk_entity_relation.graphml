  <data key="d0">Joint National Committee</data>
  <data key="d1">organization</data>
  <data key="d2">The Joint National Committee is a body that provides guidelines for the prevention, detection, evaluation, and treatment of high blood pressure.</data>
  <data key="d3">chunk-e8e236a5eba0e1dbf843d32e509da045</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136344</data>
  <data key="d6"></data>
</node>
<node id="Blood Pressure Measurement">
  <data key="d0">Blood Pressure Measurement</data>
  <data key="d1">method</data>
  <data key="d2">Blood pressure measurement is a technique used to assess the pressure in the arteries, which is critical for diagnosing hypertension.</data>
