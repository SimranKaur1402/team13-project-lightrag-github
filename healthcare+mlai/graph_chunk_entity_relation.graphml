  <data key="d0">Diabetic Nephropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Diabetic Nephropathy is a serious complication of diabetes characterized by damage to the kidneys, which can lead to end-stage renal disease.</data>
  <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136345</data>
