</node>
<node id="Optimal Control Indicators">
  <data key="d0">Optimal Control Indicators</data>
  <data key="d1">data</data>
  <data key="d2">Optimal control indicators are specific metrics used to assess and manage diabetes, including blood glucose levels and HbA1c.</data>
  <data key="d3">chunk-e5fc5e661d0f94cc23c0188b9bbe4e08</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136323</data>
