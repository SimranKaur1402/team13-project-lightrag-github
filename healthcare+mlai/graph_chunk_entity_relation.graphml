  <data key="d0">Patients with Autonomic Neuropathy</data>
  <data key="d1">group</data>
  <data key="d2">Patients with autonomic neuropathy may experience difficulties in recognizing and recovering from hypoglycaemia symptoms.</data>
  <data key="d3">chunk-ed87909b4bdb657354ca0eab1450156f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136332</data>
