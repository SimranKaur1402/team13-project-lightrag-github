<node id="Artificial Neural Network (ANN)">
  <data key="d0">Artificial Neural Network (ANN)</data>
  <data key="d1">concept</data>
  <data key="d2">Artificial Neural Network (ANN) refers to a computational model inspired by the way neurons work in the human brain, used for various machine learning tasks.</data>
  <data key="d3">chunk-af13cdaacfcf632c4d70cffbf33bfb60</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769582338</data>
