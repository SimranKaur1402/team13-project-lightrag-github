  <data key="d0">Normoglycaemia</data>
  <data key="d1">concept</data>
  <data key="d2">Normoglycaemia is a state where fasting plasma glucose levels are below specific thresholds, indicating normal glucose metabolism.</data>
  <data key="d3">chunk-42a410eaaaed4b7428f5e95a4c7c4580</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578511</data>
  <data key="d6"></data>
