</node>
<node id="Healthy Lifestyle Programmes">
  <data key="d0">Healthy Lifestyle Programmes</data>
  <data key="d1">concept</data>
  <data key="d2">Healthy Lifestyle Programmes focus on promoting healthy eating, physical activity, and other habits to reduce the risk of noncommunicable diseases, including diabetes.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578513</data>
  <data key="d6"></data>
</node>
<node id="Impaired Glucose Regulation">
  <data key="d0">Impaired Glucose Regulation</data>
  <data key="d1">concept</data>
  <data key="d2">Impaired glucose regulation refers to a stage intermediate between normoglycaemia and diabetes, representing risk categories for future diabetes development.</data>
  <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578513</data>
  <data key="d6"></data>
</node>
<node id="Impaired Fasting Glycaemia">
  <data key="d0">Impaired Fasting Glycaemia</data>
  <data key="d1">concept</data>
  <data key="d2">Impaired fasting glycaemia is characterized by fasting glucose values above the normal range but below the diagnostic threshold for diabetes.</data>
  <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578513</data>
  <data key="d6"></data>
</node>
<node id="Gestational Diabetes">
  <data key="d0">Gestational Diabetes</data>
  <data key="d1">concept</data>
  <data key="d2">Gestational diabetes encompasses conditions previously classified as gestational impaired glucose tolerance and gestational diabetes mellitus.&lt;SEP&gt;Gestational diabetes is defined as carbohydrate intolerance with onset during pregnancy and can vary in severity.&lt;SEP&gt;Gestational diabetes is a form of diabetes that occurs during pregnancy and can pose risks to both the mother and the developing fetus.</data>
  <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51&lt;SEP&gt;chunk-12fe828372a20b6606e010f0fd5e6263&lt;SEP&gt;chunk-e8e236a5eba0e1dbf843d32e509da045</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578513</data>
  <data key="d6"></data>
</node>
<node id="Malnutrition-Related Diabetes">
  <data key="d0">Malnutrition-Related Diabetes</data>
  <data key="d1">concept</data>
  <data key="d2">Malnutrition-related diabetes was proposed as a class but later recommended for deletion due to lack of convincing evidence linking it directly to malnutrition.</data>
  <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578513</data>
  <data key="d6"></data>
</node>
<node id="Epidemicity Index">
  <data key="d0">Epidemicity Index</data>
  <data key="d1">concept</data>
  <data key="d2">The epidemicity index is proposed as a ratio of IGT prevalence to diabetes mellitus prevalence, indicating the potential for future increases in type 2 diabetes prevalence.</data>
  <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578513</data>
  <data key="d6"></data>
</node>
