  <data key="d0">EMRO Technical Publications Series 32</data>
  <data key="d1">content</data>
  <data key="d2">The EMRO Technical Publications Series 32 includes guidelines focused on the prevention, management, and care of diabetes mellitus.</data>
  <data key="d3">chunk-b253411e54c35aa95f5f9179723bba3b</data>
