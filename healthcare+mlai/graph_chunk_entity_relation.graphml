<graph edgedefault="undirected"><node id="Neuropathy">
  <data key="d0">Neuropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Neuropathy is a medical condition characterized by nerve damage, often seen in diabetic patients and associated with various complications, including foot problems.&lt;SEP&gt;Neuropathy is a general term for conditions that involve damage to the peripheral nerves, and it includes various types such as diabetic neuropathy.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7&lt;SEP&gt;chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Diabetic Patients">
  <data key="d0">Diabetic Patients</data>
  <data key="d1">person</data>
  <data key="d2">Diabetic Patients are individuals diagnosed with diabetes who may require treatments such as aspirin therapy for cardiovascular protection.&lt;SEP&gt;Diabetic patients are individuals diagnosed with diabetes who may experience various complications, such as neuropathy and related foot problems.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7&lt;SEP&gt;chunk-ed87909b4bdb657354ca0eab1450156f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Foot Problems">
  <data key="d0">Foot Problems</data>
  <data key="d1">concept</data>
  <data key="d2">Foot problems refer to a range of complications that can occur in diabetic patients, including ulcers, infections, and potential amputations.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Amputation">
  <data key="d0">Amputation</data>
  <data key="d1">concept</data>
  <data key="d2">Amputation is a surgical procedure to remove a limb or body part, often necessitated by severe complications from conditions like diabetes.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Educational Programme">
  <data key="d0">Educational Programme</data>
  <data key="d1">concept</data>
  <data key="d2">The educational programme aims to enhance the knowledge and awareness of diabetic patients and physicians regarding the detection and treatment of neuropathy.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Guidelines for Prevention">
  <data key="d0">Guidelines for Prevention</data>
  <data key="d1">content</data>
  <data key="d2">The guidelines for prevention provide recommendations on managing and preventing complications related to diabetic foot issues, including education and screening.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Screening Strategy">
  <data key="d0">Screening Strategy</data>
  <data key="d1">method</data>
  <data key="d2">The screening strategy involves regular examinations of diabetic patients' feet to identify those at risk of developing foot ulcers.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Electrophysiological Study">
  <data key="d0">Electrophysiological Study</data>
  <data key="d1">method</data>
  <data key="d2">The electrophysiological study is a diagnostic method used to assess nerve function and activity, significant in researching neuropathy.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Doppler Ultrasonography">
  <data key="d0">Doppler Ultrasonography</data>
  <data key="d1">method</data>
  <data key="d2">Doppler ultrasonography is a modern investigative technique used to evaluate blood flow and vascular conditions in patients, particularly those with diabetes-related issues.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Aldose Reductase Inhibitors">
  <data key="d0">Aldose Reductase Inhibitors</data>
  <data key="d1">concept</data>
  <data key="d2">Aldose reductase inhibitors are drugs that have potential in inhibiting the pathways leading to diabetic neuropathy.&lt;SEP&gt;Aldose reductase inhibitors are therapeutic agents suggested for use in managing diabetic neuropathy, alongside traditional methods focused on symptom relief.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7&lt;SEP&gt;chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578504</data>
  <data key="d6"></data>
</node>
<node id="Lower-Limb Amputation">
  <data key="d0">Lower-Limb Amputation</data>
  <data key="d1">event</data>
  <data key="d2">Lower-limb amputation is a surgical procedure frequently performed on diabetic patients due to complications such as neuropathy and infections.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Chronic Ulceration">
  <data key="d0">Chronic Ulceration</data>
  <data key="d1">concept</data>
  <data key="d2">Chronic ulceration refers to long-term wounds often seen in diabetic patients, which can lead to severe complications like amputations.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Health Care System">
  <data key="d0">Health Care System</data>
  <data key="d1">concept</data>
  <data key="d2">The health care system encompasses all organizations and resources involved in delivering health care to patients, relevant for diabetes management and screening.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Myocardial Infarctions">
  <data key="d0">Myocardial Infarctions</data>
  <data key="d1">concept</data>
  <data key="d2">Myocardial infarctions refer to a medical condition characterized by the blockage of blood flow to the heart muscle, leading to tissue damage.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Insulin Resistance">
  <data key="d0">Insulin Resistance</data>
  <data key="d1">concept</data>
  <data key="d2">Insulin resistance is a condition associated with various characteristics of diabetes and is mentioned in the context of screening for type 2 diabetes in children.&lt;SEP&gt;Insulin resistance is a condition where cells fail to respond effectively to insulin, contributing to metabolic syndrome and increased cardiovascular risk.&lt;SEP&gt;Insulin resistance is a metabolic condition where cells in the body do not respond effectively to insulin, associated with cardiovascular risk.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-12fe828372a20b6606e010f0fd5e6263&lt;SEP&gt;chunk-e8e236a5eba0e1dbf843d32e509da045</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Dyslipidaemia">
  <data key="d0">Dyslipidaemia</data>
  <data key="d1">concept</data>
  <data key="d2">Dyslipidaemia is a condition characterized by abnormal lipid levels in the blood, often seen in individuals with diabetes.&lt;SEP&gt;Dyslipidaemia refers to abnormal levels of lipids in the blood, which can have various underlying causes that need to be ruled out.&lt;SEP&gt;Dyslipidaemia is a medical condition characterized by abnormal lipid levels, which can increase cardiovascular disease risk in individuals with type 2 diabetes.&lt;SEP&gt;Dyslipidaemia is a condition characterized by abnormal lipid levels and is associated with diabetes complications.&lt;SEP&gt;Dyslipidaemia refers to abnormal lipid levels in the blood, specifically high LDL cholesterol or triglycerides, impacting cardiovascular health.&lt;SEP&gt;Dyslipidaemia is a medical condition characterized by an abnormal amount of lipids in the blood, often requiring lifestyle management and medication.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-1b7df1782c359efe079f6ade12b3688f&lt;SEP&gt;chunk-8361af576f7e73b0bd2ea813976f60b3&lt;SEP&gt;chunk-eb1bc7614fcd68decf9461b3b6290e95&lt;SEP&gt;chunk-ed87909b4bdb657354ca0eab1450156f&lt;SEP&gt;chunk-a560aca3f99b145384c2b736c2ceea1c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Obesity">
  <data key="d0">Obesity</data>
  <data key="d1">concept</data>
  <data key="d2">Obesity is identified as a significant risk factor contributing to the development of diabetes mellitus, particularly in the Eastern Mediterranean Region.&lt;SEP&gt;Obesity is described as a condition contributing to the increasing prevalence of type 2 diabetes mellitus in children.&lt;SEP&gt;Obesity is a medical condition involving excess body fat that increases the risk of various health issues, including cardiovascular disease.&lt;SEP&gt;Obesity refers to an excess of body fat, often associated with a body mass index of 30 or greater, which can lead to health complications.&lt;SEP&gt;Obesity is a risk factor associated with diabetes and requires management within the treatment plan.&lt;SEP&gt;Obesity, particularly abdominal obesity, is closely linked to atherosclerosis and is a major factor in the risk of diabetes-related complications.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-5384df975133ef2a52113cd3ca0f897e&lt;SEP&gt;chunk-eb0252816f7fbee4c50f79ef3ee56063&lt;SEP&gt;chunk-12fe828372a20b6606e010f0fd5e6263&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-a560aca3f99b145384c2b736c2ceea1c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Blood Pressure Classification">
  <data key="d0">Blood Pressure Classification</data>
  <data key="d1">concept</data>
  <data key="d2">Blood pressure classification categorizes blood pressure levels into normal, pre-hypertension, and various stages of hypertension.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Hypertension Optimal Treatment (HOT) Trial">
  <data key="d0">Hypertension Optimal Treatment (HOT) Trial</data>
  <data key="d1">event</data>
  <data key="d2">The Hypertension Optimal Treatment (HOT) Trial is a clinical study assessing the effects of different blood pressure treatments on patient outcomes.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="United Kingdom Prospective Diabetes Study (UKPDS)">
  <data key="d0">United Kingdom Prospective Diabetes Study (UKPDS)</data>
  <data key="d1">event</data>
  <data key="d2">The United Kingdom Prospective Diabetes Study (UKPDS) is a significant study focused on the management of diabetes and its complications.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Appropriate Blood Pressure Control in Diabetes (ABCD) Study">
  <data key="d0">Appropriate Blood Pressure Control in Diabetes (ABCD) Study</data>
  <data key="d1">event</data>
  <data key="d2">The Appropriate Blood Pressure Control in Diabetes (ABCD) Study investigates methods to manage blood pressure in diabetic individuals.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578505</data>
  <data key="d6"></data>
</node>
<node id="Fasting Lipid Profile">
  <data key="d0">Fasting Lipid Profile</data>
  <data key="d1">method</data>
  <data key="d2">A fasting lipid profile is a medical test that measures lipid levels in the blood to assess cardiovascular risk in patients, particularly those with diabetes.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="LDL Cholesterol">
  <data key="d0">LDL Cholesterol</data>
  <data key="d1">data</data>
  <data key="d2">LDL cholesterol is low-density lipoprotein cholesterol, often referred to as "bad" cholesterol, associated with a higher risk of cardiovascular diseases.&lt;SEP&gt;LDL Cholesterol is a type of cholesterol targeted during therapy to reduce cardiovascular risk, specifically in patients with diabetes.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-8361af576f7e73b0bd2ea813976f60b3&lt;SEP&gt;chunk-eb0252816f7fbee4c50f79ef3ee56063&lt;SEP&gt;chunk-21112bd6ed1fe7896dbf55a52bc45a2d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Hyperglycaemia">
  <data key="d0">Hyperglycaemia</data>
  <data key="d1">concept</data>
  <data key="d2">Hyperglycaemia is characterized by excessively high blood glucose levels and can be reversed to normoglycaemia with effective treatment.&lt;SEP&gt;Hyperglycaemia is a condition of elevated blood glucose levels, often associated with diabetes and metabolic syndrome.&lt;SEP&gt;Hyperglycaemia is a condition characterized by elevated blood sugar levels, often necessitating treatment to reduce cardiovascular risk in patients with diabetes.&lt;SEP&gt;Hyperglycaemia, or high blood sugar, is a condition that can promote atherosclerosis and other complications linked to diabetes.&lt;SEP&gt;Hyperglycaemia is a condition associated with diabetes that affects nerve structure through several biochemical mechanisms.&lt;SEP&gt;Hyperglycaemia is a condition of elevated blood sugar levels potentially leading to complications like renal damage.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-0748670b42b0f4e0b2ed9c5ce62d54e7&lt;SEP&gt;chunk-42a410eaaaed4b7428f5e95a4c7c4580&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-e8e236a5eba0e1dbf843d32e509da045&lt;SEP&gt;chunk-fd4cfbed43aa26af0eef694fecac2177</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Cardiovascular Mortality">
  <data key="d0">Cardiovascular Mortality</data>
  <data key="d1">concept</data>
  <data key="d2">Cardiovascular mortality refers to deaths caused by diseases related to the heart and blood vessels, which can be significantly increased in patients with diabetes.</data>
  <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Hypothyroidism">
  <data key="d0">Hypothyroidism</data>
  <data key="d1">condition</data>
  <data key="d2">Hypothyroidism is a condition characterized by insufficient thyroid hormone production, which can be assessed by measuring thyroid-stimulating hormone levels.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Obstructive Liver Disease">
  <data key="d0">Obstructive Liver Disease</data>
  <data key="d1">condition</data>
  <data key="d2">Obstructive liver disease affects liver function and can be evaluated through liver function tests.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Chronic Renal Disease">
  <data key="d0">Chronic Renal Disease</data>
  <data key="d1">condition</data>
  <data key="d2">Chronic renal disease involves long-term kidney dysfunction, assessed via renal function tests and creatinine clearance.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Brittle Diabetes">
  <data key="d0">Brittle Diabetes</data>
  <data key="d1">condition</data>
  <data key="d2">Brittle diabetes refers to type 1 diabetes patients who experience severe fluctuations in blood glucose levels despite treatment efforts.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Type 1 Diabetes Mellitus">
  <data key="d0">Type 1 Diabetes Mellitus</data>
  <data key="d1">concept</data>
  <data key="d2">Type 1 diabetes mellitus is characterized by the majority of cases being due to pancreatic islet ß-cell destruction, and it is prone to ketoacidosis.&lt;SEP&gt;Type 1 diabetes mellitus is an autoimmune condition characterized by insufficient insulin production.&lt;SEP&gt;Type 1 diabetes mellitus is characterized by the destruction of insulin-producing beta cells, necessitating insulin for survival.&lt;SEP&gt;Type 1 diabetes mellitus is an autoimmune condition where the pancreas produces little to no insulin.&lt;SEP&gt;Type 1 diabetes mellitus is a chronic condition characterized by the body's inability to produce insulin, leading to increased risk for complications like nephropathy.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f&lt;SEP&gt;chunk-42a410eaaaed4b7428f5e95a4c7c4580&lt;SEP&gt;chunk-92fbe09a650e62b7b6ea5d8769440e51&lt;SEP&gt;chunk-85ef35aaa38ac4f0c032c8bc3f6df559&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2&lt;SEP&gt;chunk-25fb88c8ed14936954356d104de095d4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Diabetic Ketoacidosis">
  <data key="d0">Diabetic Ketoacidosis</data>
  <data key="d1">condition</data>
  <data key="d2">Diabetic ketoacidosis is a severe complication of diabetes characterized by high blood sugar and ketone levels, requiring immediate medical intervention.&lt;SEP&gt;Diabetic ketoacidosis is a serious complication of diabetes that can be precipitated by infections, leading to severe metabolic disturbances.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578506</data>
  <data key="d6"></data>
</node>
<node id="Mass Community Screening">
  <data key="d0">Mass Community Screening</data>
  <data key="d1">concept</data>
  <data key="d2">Mass community screening refers to the practice of testing large populations for diseases such as diabetes, which can lead to earlier diagnosis and treatment.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578507</data>
  <data key="d6"></data>
</node>
<node id="Screening Programme">
  <data key="d0">Screening Programme</data>
  <data key="d1">concept</data>
  <data key="d2">A screening programme is a structured approach to detecting diseases in populations, aimed at improving public health.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578507</data>
  <data key="d6"></data>
</node>
<node id="Glycated Haemoglobin">
  <data key="d0">Glycated Haemoglobin</data>
  <data key="d1">data</data>
  <data key="d2">Glycated haemoglobin is a blood test that reflects average blood sugar levels over a period of time, used in diabetes management.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578507</data>
  <data key="d6"></data>
</node>
<node id="1,5-Anhydroglucitol">
  <data key="d0">1,5-Anhydroglucitol</data>
  <data key="d1">data</data>
  <data key="d2">1,5-Anhydroglucitol is a potential biomarker for blood sugar levels, although less specific for detecting diabetes.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578507</data>
  <data key="d6"></data>
</node>
<node id="Insulin Regimen">
  <data key="d0">Insulin Regimen</data>
  <data key="d1">concept</data>
  <data key="d2">Insulin regimen refers to the prescribed dose and timing of insulin used to manage blood sugar levels in diabetes patients.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578507</data>
  <data key="d6"></data>
</node>
<node id="Epidemiological Studies">
  <data key="d0">Epidemiological Studies</data>
  <data key="d1">concept</data>
  <data key="d2">Epidemiological studies are research investigations that study the patterns, causes, and effects of health and disease conditions in defined populations.</data>
  <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
