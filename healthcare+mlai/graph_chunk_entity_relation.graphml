  <data key="d4">unknown_source</data>
  <data key="d5">1769578514</data>
  <data key="d6"></data>
</node>
<node id="Vector Toxicity">
  <data key="d0">Vector Toxicity</data>
  <data key="d1">concept</data>
  <data key="d2">Vector toxicity refers to rare instances of type 1 diabetes presenting in pregnancy that may require insulin for survival.</data>
