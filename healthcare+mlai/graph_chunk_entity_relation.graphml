  <data key="d0">Screening for Type 2 Diabetes Mellitus</data>
  <data key="d1">method</data>
  <data key="d2">Screening for type 2 diabetes mellitus is a method aimed at early identification of individuals at high risk for diabetes and related health issues.</data>
  <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Regional Training Course for Diabetes Educators">
  <data key="d0">Regional Training Course for Diabetes Educators</data>
  <data key="d1">method</data>
  <data key="d2">The regional training course for diabetes educators is designed to train individuals in diabetes care practices and teaching methodologies.</data>
  <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="National Strategy for Diabetes Management">
  <data key="d0">National Strategy for Diabetes Management</data>
  <data key="d1">concept</data>
  <data key="d2">The National Strategy for Diabetes Management aims to establish comprehensive approaches for the control of diabetes and associated health conditions.</data>
  <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Ketoacidosis">
  <data key="d0">Ketoacidosis</data>
  <data key="d1">concept</data>
  <data key="d2">Ketoacidosis is a severe complication of diabetes, primarily affecting those with type 1 diabetes, marked by high levels of ketones in the blood.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Emergency Medical Personnel">
  <data key="d0">Emergency Medical Personnel</data>
  <data key="d1">person</data>
  <data key="d2">Emergency medical personnel are health care workers trained to recognize and treat conditions like hypoglycaemia and ketoacidosis.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Blood Glucose">
  <data key="d0">Blood Glucose</data>
  <data key="d1">data</data>
  <data key="d2">Blood glucose refers to the level of sugar in the blood, essential for monitoring in patients with diabetes.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Glucagon">
  <data key="d0">Glucagon</data>
  <data key="d1">data</data>
  <data key="d2">Glucagon is a hormone used in emergency situations to raise blood sugar levels, especially in cases of severe hypoglycaemia.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Type 1 Diabetes">
  <data key="d0">Type 1 Diabetes</data>
  <data key="d1">concept</data>
  <data key="d2">Type 1 diabetes is an autoimmune condition where the body fails to produce insulin, often leading to conditions like ketoacidosis.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97&lt;SEP&gt;chunk-eb1bc7614fcd68decf9461b3b6290e95</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Health Care Workers">
  <data key="d0">Health Care Workers</data>
  <data key="d1">person</data>
  <data key="d2">Health care workers are professionals involved in the recognition and treatment of conditions related to diabetes, such as hypoglycaemia.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Chronic Painless Infection">
  <data key="d0">Chronic Painless Infection</data>
  <data key="d1">concept</data>
  <data key="d2">Chronic painless infection is a type of infection that may commonly affect individuals with poorly controlled diabetes, leading to serious complications.&lt;SEP&gt;Chronic painless infections in diabetic patients can lead to severe complications, particularly affecting neuropathic and ischaemic feet.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Urinary Tract Infections">
  <data key="d0">Urinary Tract Infections</data>
  <data key="d1">concept</data>
  <data key="d2">Urinary tract infections are common complications for diabetic patients, often exacerbated by bladder instrumentation or other factors.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Diabetic Nephropathy">
  <data key="d0">Diabetic Nephropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Diabetic nephropathy is a kidney-related complication arising from diabetes, often aggravated by urinary tract infections.&lt;SEP&gt;Diabetic nephropathy is a common kidney disease in diabetic patients and a major cause of renal failure, developing through several stages.&lt;SEP&gt;Diabetic Nephropathy is a complication of diabetes characterized by kidney damage resulting from prolonged high levels of glucose.</data>
  <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2&lt;SEP&gt;chunk-fd4cfbed43aa26af0eef694fecac2177</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Ulin-Receptor Antibodies">
  <data key="d0">Ulin-Receptor Antibodies</data>
  <data key="d1">concept</data>
  <data key="d2">Ulin-receptor antibodies are discussed in relation to various genetic syndromes associated with diabetes.</data>
  <data key="d3">chunk-12fe828372a20b6606e010f0fd5e6263</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578531</data>
  <data key="d6"></data>
</node>
<node id="Klinefelter Syndrome">
  <data key="d0">Klinefelter Syndrome</data>
  <data key="d1">other</data>
  <data key="d2">Klinefelter syndrome is a rare genetic syndrome associated with diabetes.</data>
  <data key="d3">chunk-12fe828372a20b6606e010f0fd5e6263</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769578532</data>
  <data key="d6"></data>
</node>
<node id="Down Syndrome">
  <data key="d0">Down Syndrome</data>
  <data key="d1">other</data>
  <data key="d2">Down syndrome is another rare genetic syndrome associated with diabetes.</data>
  <data key="d3">chunk-12fe828372a20b6606e010f0fd5e6263</data>
