  <data key="d1">concept</data>
  <data key="d2">Microvascular complications are potential health issues associated with high fasting glucose values above 6.1 mmol/L.</data>
  <data key="d3">chunk-42a410eaaaed4b7428f5e95a4c7c4580</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136332</data>
