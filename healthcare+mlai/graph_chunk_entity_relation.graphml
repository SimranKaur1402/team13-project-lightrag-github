<node id="IoT Based Glucose Monitoring Algorithm">
  <data key="d0">IoT Based Glucose Monitoring Algorithm</data>
  <data key="d1">concept</data>
  <data key="d2">The IoT-Based Glucose Monitoring Algorithm is designed to help prevent diabetes complications through real-time monitoring.</data>
  <data key="d3">chunk-555791724a47d3b0dffcfb8dc87864e4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769582103</data>
