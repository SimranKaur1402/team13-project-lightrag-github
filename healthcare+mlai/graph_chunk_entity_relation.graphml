<node id="Diabetes Prevention and Control Consultation">
  <data key="d0">Diabetes Prevention and Control Consultation</data>
  <data key="d1">event</data>
  <data key="d2">The regional consultation on diabetes prevention and control focuses on strategies to address diabetes as a public health challenge.</data>
  <data key="d3">chunk-b253411e54c35aa95f5f9179723bba3b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136308</data>
