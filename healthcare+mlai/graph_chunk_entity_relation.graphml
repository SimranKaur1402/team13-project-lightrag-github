  <data key="d0">Screening Strategies for Neuropathy</data>
  <data key="d1">method</data>
  <data key="d2">Screening strategies for neuropathy include testing and inspection for early detection of various symptoms.</data>
  <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136322</data>
  <data key="d6"></data>
</node>
<node id="Economic Barriers">
  <data key="d0">Economic Barriers</data>
  <data key="d1">concept</data>
  <data key="d2">Economic barriers refer to the lack of resources that prevent patients from seeking appropriate care for diabetic neuropathy.</data>
  <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1770136322</data>
