    <node id="Neuropathy">
      <data key="d0">Neuropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Neuropathy is a general term for nerve damage, which can occur in various forms, including diabetic neuropathy.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894214</data>
      <data key="d6" />
    </node>
    <node id="Neurological Assessment">
      <data key="d0">Neurological Assessment</data>
      <data key="d1">concept</data>
      <data key="d2">Neurological assessment refers to a comprehensive evaluation of the nervous system, particularly in patients with potential neuropathy.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894214</data>
