    <node id="United Kingdom Prospective Diabetes Study Group">
      <data key="d0">United Kingdom Prospective Diabetes Study Group</data>
      <data key="d1">organization</data>
      <data key="d2">The United Kingdom Prospective Diabetes Study Group is a research group studying diabetes management and its complications.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894234</data>
      <data key="d6" />
    </node>
    <node id="Visual Acuity">
      <data key="d0">Visual Acuity</data>
      <data key="d1">concept</data>
      <data key="d2">Visual acuity refers to the clarity or sharpness of vision, which can be impacted by diabetic complications such as retinopathy.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
