    <node id="Hypoglycemia">
      <data key="d0">Hypoglycemia</data>
      <data key="d1">concept</data>
      <data key="d2">Hypoglycemia refers to abnormally low levels of blood glucose, requiring appropriate education for management and recognition among patients and healthcare providers.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894229</data>
      <data key="d6" />
    </node>
    <node id="Type 1 Diabetes">
      <data key="d0">Type 1 Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Type 1 diabetes is a form of diabetes where the pancreas produces little or no insulin, often leading to ketoacidosis in new patients.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Emergency Medical Personnel">
      <data key="d0">Emergency Medical Personnel</data>
      <data key="d1">person</data>
      <data key="d2">Emergency medical personnel are healthcare workers who provide urgent care and should be knowledgeable about recognizing and treating conditions such as hypoglycemia and ketoacidosis.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Glucagon">
      <data key="d0">Glucagon</data>
      <data key="d1">method</data>
      <data key="d2">Glucagon is a medication used to treat severe hypoglycemia in individuals with diabetes, and it should be readily available in emergency situations.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Acute Complications of Diabetes Mellitus">
      <data key="d0">Acute Complications of Diabetes Mellitus</data>
      <data key="d1">concept</data>
      <data key="d2">Acute complications of diabetes mellitus refer to immediate health risks associated with poor diabetes management, including hypoglycemia and ketoacidosis.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Chronic Painless Infection">
      <data key="d0">Chronic Painless Infection</data>
      <data key="d1">concept</data>
      <data key="d2">Chronic painless infection is a condition that can affect individuals with poorly controlled diabetes, potentially leading to significant health problems.&lt;SEP&gt;Chronic painless infection is a condition that canDestroy neuropathic and/or ischaemic feet in diabetic patients.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Diabetic Nephropathy">
      <data key="d0">Diabetic Nephropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetic Nephropathy is a kidney-related complication that can be aggravated by conditions such as pyelitis and pyelonephritis in diabetes patients.&lt;SEP&gt;Diabetic nephropathy is a kidney-related complication that can result from chronic diabetes, exacerbated by conditions such as pyelitis and urinary tract infections.&lt;SEP&gt;Diabetic nephropathy is kidney damage that occurs in diabetic patients, necessitating careful management and potential interventions.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-fd4cfbed43aa26af0eef694fecac2177&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Health Care Personnel">
      <data key="d0">Health Care Personnel</data>
      <data key="d1">person</data>
      <data key="d2">Health care personnel are professionals responsible for patient care and should be informed about diabetes management and emergency interventions.</data>
      <data key="d3">chunk-76910bb9e0e5a60b043dd2786bf63e97</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Impaired Glucose Regulation">
      <data key="d0">Impaired Glucose Regulation</data>
      <data key="d1">concept</data>
      <data key="d2">Impaired Glucose Regulation refers to conditions intermediate between normal glucose tolerance and diabetes, indicating risk for future diabetes development.</data>
      <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Impaired Fasting Glycaemia">
      <data key="d0">Impaired Fasting Glycaemia</data>
      <data key="d1">concept</data>
      <data key="d2">Impaired Fasting Glycaemia is classified for individuals who have elevated fasting glucose levels but not high enough for diabetes diagnosis.</data>
      <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Malnutrition Related Diabetes">
      <data key="d0">Malnutrition Related Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Malnutrition Related Diabetes was proposed as a classification of diabetes influenced by malnutrition but has since been recommended for deletion.</data>
      <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
      <data key="d6" />
    </node>
    <node id="Gestational Diabetes">
      <data key="d0">Gestational Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Gestational Diabetes is retained as a term for diabetes that develops during pregnancy, including former classifications of gestational impaired glucose tolerance.&lt;SEP&gt;Gestational diabetes is a type of diabetes arising during pregnancy characterized by carbohydrate intolerance.</data>
      <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51&lt;SEP&gt;chunk-12fe828372a20b6606e010f0fd5e6263</data>
