      <data key="d0">Cystic Fibrosis</data>
      <data key="d1">concept</data>
      <data key="d2">Cystic Fibrosis is a genetic disorder referenced as a specific cause of beta-cell destruction impacting diabetes classification.</data>
      <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
      <data key="d6" />
    </node>
    <node id="Mitochondrial Defect">
