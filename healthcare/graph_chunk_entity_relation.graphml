      <data key="d0">Diabetes Mellitus - Prevention</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetes Mellitus - Prevention refers to methods and strategies aimed at preventing the onset of diabetes mellitus.</data>
      <data key="d3">chunk-b253411e54c35aa95f5f9179723bba3b</data>
