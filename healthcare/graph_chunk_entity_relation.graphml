    <node id="Normoglycaemia">
      <data key="d0">Normoglycaemia</data>
      <data key="d1">concept</data>
      <data key="d2">Normoglycaemia is defined as normal fasting plasma glucose levels and indicates healthy glucose metabolism.</data>
      <data key="d3">chunk-42a410eaaaed4b7428f5e95a4c7c4580</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894221</data>
