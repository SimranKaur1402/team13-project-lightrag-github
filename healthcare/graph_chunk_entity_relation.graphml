    <node id="Obesity Pandemic">
      <data key="d0">Obesity Pandemic</data>
      <data key="d1">concept</data>
      <data key="d2">The obesity pandemic refers to the widespread increase in obesity rates which contributes significantly to the rise of type 2 diabetes.</data>
      <data key="d3">chunk-d8c827cc2249067692290d6a8a0e8018</data>
