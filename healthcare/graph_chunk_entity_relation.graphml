    </node>
    <node id="Obstruction">
      <data key="d0">Obstruction</data>
      <data key="d1">concept</data>
      <data key="d2">Obstruction is a condition that can contribute to urinary tract infections, particularly in individuals with diabetes.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894233</data>
      <data key="d6" />
