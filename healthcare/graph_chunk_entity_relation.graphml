      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
      <data key="d6" />
    </node>
    <node id="Hypothyroidism">
      <data key="d0">Hypothyroidism</data>
      <data key="d1">concept</data>
      <data key="d2">Hypothyroidism is a condition where the thyroid gland does not produce sufficient hormones, which can be assessed through thyroid-stimulating hormone levels.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
      <data key="d6" />
    </node>
    <node id="Obstructive Liver Disease">
      <data key="d0">Obstructive Liver Disease</data>
      <data key="d1">concept</data>
      <data key="d2">Obstructive liver disease refers to conditions that block bile ducts and impair liver function, assessed through liver function tests.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
      <data key="d6" />
    </node>
    <node id="Chronic Renal Disease">
      <data key="d0">Chronic Renal Disease</data>
      <data key="d1">concept</data>
      <data key="d2">Chronic renal disease is a long-term condition characterized by a gradual loss of kidney function, evaluated through renal function tests and urinalysis.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
      <data key="d6" />
    </node>
    <node id="Diabetic Ketoacidosis">
      <data key="d0">Diabetic Ketoacidosis</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetic ketoacidosis is a serious complication of diabetes characterized by high levels of ketones and blood sugar, leading to metabolic acidosis.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
