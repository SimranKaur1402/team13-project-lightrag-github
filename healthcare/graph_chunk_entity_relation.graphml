    </node>
    <node id="Patient Factors">
      <data key="d0">Patient Factors</data>
      <data key="d1">concept</data>
      <data key="d2">Patient factors are aspects related to the awareness and access to care that can cause delays in recognizing vision-threatening retinopathy.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894234</data>
