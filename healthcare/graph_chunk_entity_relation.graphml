      <data key="d1">method</data>
      <data key="d2">Glucose measurement is a diagnostic procedure that assesses blood sugar levels to help identify diabetes.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894232</data>
