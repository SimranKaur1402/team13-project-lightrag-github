    </node>
    <node id="Ophthalmologist">
      <data key="d0">Ophthalmologist</data>
      <data key="d1">person</data>
      <data key="d2">An ophthalmologist is a medical doctor specialized in eye care, including screening for diabetic eye diseases and complications.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894234</data>
      <data key="d6" />
