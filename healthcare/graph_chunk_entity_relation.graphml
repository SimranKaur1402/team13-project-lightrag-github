      <data key="d0">Physician Factors</data>
      <data key="d1">concept</data>
      <data key="d2">Physician factors refer to issues that can delay the discovery of diabetes-related eye complications, such as skills and knowledge deficiencies.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894234</data>
