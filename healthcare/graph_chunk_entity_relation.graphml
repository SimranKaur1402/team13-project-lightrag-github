    <node id="Renal Replacement Therapy">
      <data key="d0">Renal Replacement Therapy</data>
      <data key="d1">method</data>
      <data key="d2">Renal replacement therapy includes techniques such as dialysis or transplantation, used for patients with end-stage renal disease.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894240</data>
