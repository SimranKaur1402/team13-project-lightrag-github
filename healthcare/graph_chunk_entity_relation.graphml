      <data key="d0">End-Stage Renal Disease</data>
      <data key="d1">concept</data>
      <data key="d2">End-stage renal disease is the final stage of chronic kidney disease, requiring dialysis or kidney transplantation for survival.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894241</data>
