    <node id="Diabetic Retinopathy">
      <data key="d0">Diabetic Retinopathy</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetic Retinopathy is characterized by eye complications that can lead to blindness, primarily affecting individuals with longer-term diabetes.&lt;SEP&gt;Diabetic retinopathy is a specific eye disease associated with diabetes, characterized by damage to the retina due to high blood sugar levels.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-7ef79f22f40772c2060b439008ce485b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894233</data>
      <data key="d6" />
    </node>
    <node id="Aspirin">
      <data key="d0">Aspirin</data>
      <data key="d1">medication</data>
      <data key="d2">Aspirin is recommended for diabetic patients as it is effective for primary and secondary prevention against cardiovascular diseases.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894233</data>
      <data key="d6" />
    </node>
    <node id="Bladder Instrumentation">
      <data key="d0">Bladder Instrumentation</data>
      <data key="d1">method</data>
      <data key="d2">Bladder instrumentation refers to medical procedures performed on the bladder, which can increase the risk of urinary tract infections in diabetic patients.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894233</data>
