      <data key="d0">National and Regional Databases</data>
      <data key="d1">data</data>
      <data key="d2">National and regional databases are systems used to store and provide information regarding patients needing renal replacement therapy and monitoring outcomes.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894241</data>
      <data key="d6" />
    </node>
    <node id="Nephrotoxic Drugs">
      <data key="d0">Nephrotoxic Drugs</data>
      <data key="d1">concept</data>
      <data key="d2">Nephrotoxic drugs are medications that may cause damage to the kidneys, particularly in patients with diabetes and nephropathy.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894241</data>
