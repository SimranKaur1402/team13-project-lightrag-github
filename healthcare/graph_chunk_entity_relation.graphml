    <node id="Creatinine Clearance">
      <data key="d0">Creatinine Clearance</data>
      <data key="d1">concept</data>
      <data key="d2">Creatinine clearance is a test used to evaluate kidney function by measuring the rate at which creatinine is removed from the blood.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894232</data>
      <data key="d6" />
    </node>
    <node id="Urinalysis">
      <data key="d0">Urinalysis</data>
      <data key="d1">method</data>
      <data key="d2">Urinalysis is a test that examines urine for various components, important for diagnosing conditions related to kidney function and other diseases.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894232</data>
      <data key="d6" />
    </node>
    <node id="Liver Function Tests">
      <data key="d0">Liver Function Tests</data>
      <data key="d1">method</data>
      <data key="d2">Liver function tests are blood tests used to assess the health of the liver and to detect liver damage or disease.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894232</data>
      <data key="d6" />
    </node>
    <node id="Urinary Tract Infections">
      <data key="d0">Urinary Tract Infections</data>
      <data key="d1">concept</data>
      <data key="d2">Urinary tract infections are common among diabetics, particularly after bladder instrumentation, and can result from various factors.&lt;SEP&gt;Urinary tract infections are infections that may occur in patients with kidney disease, requiring vigorous treatment to avoid complications.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-fd4cfbed43aa26af0eef694fecac2177</data>
