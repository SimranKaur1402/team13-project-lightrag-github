    </node>
    <node id="Fluid Retention">
      <data key="d0">Fluid Retention</data>
      <data key="d1">concept</data>
      <data key="d2">Fluid retention is a condition where excess fluids build up in the body, often related to kidney dysfunction, requiring medical intervention.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894240</data>
