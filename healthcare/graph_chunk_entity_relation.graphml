    <node id="Diabetes Education">
      <data key="d0">Diabetes Education</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetes education involves teaching individuals about managing their condition, including self-monitoring and lifestyle changes.&lt;SEP&gt;Diabetes education encompasses various forms and methods aimed at promoting awareness and management of diabetes.</data>
      <data key="d3">chunk-2173942c84747feba52cff952903a7f5&lt;SEP&gt;chunk-a560aca3f99b145384c2b736c2ceea1c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Primary Prevention of Diabetes">
      <data key="d0">Primary Prevention of Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Primary prevention of diabetes involves strategies aimed at preventing the onset of diabetes through healthy lifestyle choices.</data>
      <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Healthy Lifestyles Programmes">
      <data key="d0">Healthy Lifestyles Programmes</data>
      <data key="d1">concept</data>
      <data key="d2">Healthy lifestyles programmes focus on maintaining normal weight and promoting an active lifestyle as a strategy to prevent diabetes.</data>
      <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Screening for Type 2 Diabetes Mellitus">
      <data key="d0">Screening for Type 2 Diabetes Mellitus</data>
      <data key="d1">concept</data>
      <data key="d2">Screening for type 2 diabetes mellitus is an essential process aimed at early identification of individuals at risk for diabetes and related health complications.</data>
      <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Integrated Approach to Prevention and Care">
      <data key="d0">Integrated Approach to Prevention and Care</data>
      <data key="d1">concept</data>
      <data key="d2">An integrated approach to prevention and care of diabetes mellitus encompasses comprehensive strategies for management and prevention.</data>
      <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Regional Training Course for Diabetes Educators">
      <data key="d0">Regional Training Course for Diabetes Educators</data>
      <data key="d1">concept</data>
      <data key="d2">A regional training course for diabetes educators is proposed to enhance knowledge and skills in diabetes management and education.</data>
      <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="National Diabetes Control Programme">
      <data key="d0">National Diabetes Control Programme</data>
      <data key="d1">concept</data>
      <data key="d2">A national diabetes control programme aims to implement strategies for managing and preventing diabetes at the national level.</data>
      <data key="d3">chunk-2173942c84747feba52cff952903a7f5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Myocardial Infarctions">
      <data key="d0">Myocardial Infarctions</data>
      <data key="d1">concept</data>
      <data key="d2">Myocardial infarctions are serious medical conditions characterized by the obstruction of blood flow to the heart, noted for a decrease of 11% in incidence.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Insulin Resistance">
      <data key="d0">Insulin Resistance</data>
      <data key="d1">concept</data>
      <data key="d2">Insulin resistance is a metabolic disorder where cells become less responsive to insulin, leading to increased cardiovascular risk.&lt;SEP&gt;Insulin resistance is a condition where cells fail to respond adequately to insulin, often seen in individuals with type 2 diabetes.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894227</data>
      <data key="d6" />
    </node>
    <node id="Blood Pressure Classification">
      <data key="d0">Blood Pressure Classification</data>
      <data key="d1">concept</data>
      <data key="d2">Blood pressure classification categorizes blood pressure levels to determine risk statuses for adults aged 18 and older.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894228</data>
      <data key="d6" />
    </node>
    <node id="Treatment of Hyperglycaemia">
      <data key="d0">Treatment of Hyperglycaemia</data>
      <data key="d1">method</data>
      <data key="d2">The treatment of hyperglycaemia involves managing high blood sugar levels, but is often insufficient alone to address cardiovascular mortality risks.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894228</data>
      <data key="d6" />
    </node>
    <node id="Antihypertensive Therapy">
      <data key="d0">Antihypertensive Therapy</data>
      <data key="d1">method</data>
      <data key="d2">Antihypertensive therapy includes medications used to lower high blood pressure and mitigate cardiovascular risk.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894228</data>
      <data key="d6" />
    </node>
    <node id="Cardiovascular Events">
      <data key="d0">Cardiovascular Events</data>
      <data key="d1">event</data>
      <data key="d2">Cardiovascular events refer to incidents such as heart attacks or strokes that can arise from managing high blood pressure.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894228</data>
      <data key="d6" />
    </node>
    <node id="Fasting Lipid Profile">
      <data key="d0">Fasting Lipid Profile</data>
      <data key="d1">method</data>
      <data key="d2">A fasting lipid profile is a blood test used to measure lipid levels in patients, recommended annually for those with diabetes.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894228</data>
      <data key="d6" />
    </node>
    <node id="HDL Cholesterol">
      <data key="d0">HDL Cholesterol</data>
      <data key="d1">concept</data>
      <data key="d2">HDL cholesterol is known as "good" cholesterol, which helps protect against heart disease by facilitating cholesterol transport.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894228</data>
      <data key="d6" />
    </node>
    <node id="Screening Guidelines">
      <data key="d0">Screening Guidelines</data>
      <data key="d1">concept</data>
      <data key="d2">Screening guidelines refer to recommended procedures for monitoring and diagnosing conditions such as hypertension and dyslipidaemia in patients, particularly those with diabetes.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894228</data>
      <data key="d6" />
    </node>
    <node id="Brittle Diabetes">
      <data key="d0">Brittle Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Brittle diabetes refers to a form of diabetes characterized by unstable blood sugar levels, often leading to severe complications.&lt;SEP&gt;Brittle diabetes refers to patients, typically with type 1 diabetes, who experience severe fluctuations in blood glucose levels despite treatment efforts.</data>
      <data key="d3">chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894229</data>
      <data key="d6" />
    </node>
