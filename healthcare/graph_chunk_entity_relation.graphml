    </node>
    <node id="Dyslipidaemia Management Goals">
      <data key="d0">Dyslipidaemia Management Goals</data>
      <data key="d1">concept</data>
      <data key="d2">Dyslipidaemia Management Goals focus on achieving target LDL cholesterol levels and addressing triglycerides to mitigate cardiovascular risks.</data>
      <data key="d3">chunk-8361af576f7e73b0bd2ea813976f60b3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894218</data>
      <data key="d6" />
