      <data key="d0">Angiotensin-Converting Enzyme Inhibitors</data>
      <data key="d1">method</data>
      <data key="d2">Angiotensin-converting enzyme inhibitors are a class of medication used to manage hypertension and protect kidney function.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894240</data>
      <data key="d6" />
    </node>
    <node id="Angiotensin Receptor Blockers">
      <data key="d0">Angiotensin Receptor Blockers</data>
      <data key="d1">method</data>
      <data key="d2">Angiotensin receptor blockers are medications that help lower blood pressure and are used in treating kidney diseases related to hypertension.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894240</data>
      <data key="d6" />
    </node>
    <node id="Dietary Protein Restriction">
      <data key="d0">Dietary Protein Restriction</data>
      <data key="d1">method</data>
      <data key="d2">Dietary protein restriction involves limiting protein intake to help manage kidney health and decrease renal perfusion.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894240</data>
