    <node id="Pan-Retinal Laser Photocoagulation">
      <data key="d0">Pan-Retinal Laser Photocoagulation</data>
      <data key="d1">method</data>
      <data key="d2">Pan-retinal laser photocoagulation is a treatment method for eyes with advanced proliferative retinopathy, effective in preventing severe vision loss.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894234</data>
