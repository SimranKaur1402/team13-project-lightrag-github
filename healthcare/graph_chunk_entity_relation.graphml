      <data key="d0">Diabetes Prevalence</data>
      <data key="d1">data</data>
      <data key="d2">Diabetes prevalence denotes the estimated number of individuals affected by diabetes and its various types globally.</data>
      <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894230</data>
