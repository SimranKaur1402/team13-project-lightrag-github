  <graph edgedefault="undirected">
    <node id="α-Glucosidase Inhibitors">
      <data key="d0">α-Glucosidase Inhibitors</data>
      <data key="d1">concept</data>
      <data key="d2">α-glucosidase inhibitors are medications that delay carbohydrate absorption in the body, used in diabetes treatment.&lt;SEP&gt;α-Glucosidase inhibitors are oral medications that delay carbohydrate absorption in the intestine.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32&lt;SEP&gt;chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="Acarbose">
      <data key="d0">Acarbose</data>
      <data key="d1">content</data>
      <data key="d2">Acarbose is an α-glucosidase inhibitor taken at a dosage of 100–300 mg/day to delay carbohydrate absorption.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="Miglitol">
      <data key="d0">Miglitol</data>
      <data key="d1">content</data>
      <data key="d2">Miglitol is another α-glucosidase inhibitor administered in a dosage of 100–300 mg/day to delay carbohydrate absorption.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="Insulin">
      <data key="d0">Insulin</data>
      <data key="d1">method</data>
      <data key="d2">Insulin is a hormone critical for glucose metabolism, required by those with Type 1 Diabetes Mellitus for survival.&lt;SEP&gt;Insulin is a hormone used as a treatment for diabetes, particularly essential for individuals with type 1 diabetes.&lt;SEP&gt;Insulin is a hormone used in diabetes management with various action types and durations.&lt;SEP&gt;Insulin is a hormone involved in regulating blood sugar levels, and its management is crucial for preventing complications in diabetic patients.&lt;SEP&gt;Insulin is a hormone used in the management of diabetes to regulate blood sugar levels and prevent complications such as diabetic ketoacidosis.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32&lt;SEP&gt;chunk-76910bb9e0e5a60b043dd2786bf63e97&lt;SEP&gt;chunk-92fbe09a650e62b7b6ea5d8769440e51&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-a560aca3f99b145384c2b736c2ceea1c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="NPH">
      <data key="d0">NPH</data>
      <data key="d1">concept</data>
      <data key="d2">NPH (Neutral Protamine Hagedorn) is an intermediate-acting insulin type with a specific onset and duration of action.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="Insulin Analogs">
      <data key="d0">Insulin Analogs</data>
      <data key="d1">concept</data>
      <data key="d2">Insulin analogs are modified forms of insulin that offer different action profiles for diabetes management.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="Multidisciplinary Mini Clinics">
      <data key="d0">Multidisciplinary Mini Clinics</data>
      <data key="d1">concept</data>
      <data key="d2">Multidisciplinary mini clinics provide team care for diabetes, improving clinical outcomes and treatment efficiency.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="Basal-Bolus Method">
      <data key="d0">Basal-Bolus Method</data>
      <data key="d1">method</data>
      <data key="d2">The basal-bolus method is an insulin regimen for diabetes management, involving both long-acting and rapid-acting insulins.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894210</data>
      <data key="d6" />
    </node>
    <node id="Metformin">
      <data key="d0">Metformin</data>
      <data key="d1">content</data>
      <data key="d2">Metformin is an oral diabetes medication preferred for fasting due to its low risk of hypoglycemia.&lt;SEP&gt;Metformin is a medication used to lower blood sugar levels by decreasing hepatic glucose production and increasing insulin sensitivity.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32&lt;SEP&gt;chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="Thiazolidinediones">
      <data key="d0">Thiazolidinediones</data>
      <data key="d1">content</data>
      <data key="d2">Thiazolidinediones are oral agents with a lower risk of hypoglycemia, suitable for diabetes patients.&lt;SEP&gt;Thiazolidinediones are medications that increase insulin sensitivity and decrease hepatic glucose production.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32&lt;SEP&gt;chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="Hypertension">
      <data key="d0">Hypertension</data>
      <data key="d1">concept</data>
      <data key="d2">Hypertension, or high blood pressure, is a condition that significantly contributes to the risk of cardiovascular diseases, particularly in patients with diabetes.&lt;SEP&gt;Hypertension is a chronic medical condition defined by consistently elevated blood pressure levels, often leading to cardiovascular complications.&lt;SEP&gt;Hypertension refers to high blood pressure, which is a condition that can complicate type 2 diabetes and increase cardiovascular risks.&lt;SEP&gt;Hypertension refers to high blood pressure, which requires specific management in patients with diabetes.&lt;SEP&gt;Hypertension is a condition characterized by persistently high blood pressure, which impacts various health issues, including kidney disease.&lt;SEP&gt;Hypertension is a chronic medical condition characterized by persistently elevated blood pressure, which can increase the risk of heart disease and other complications, including type 2 diabetes.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32&lt;SEP&gt;chunk-c4d75b2c01d2448f37de4deec12208fa&lt;SEP&gt;chunk-eb1bc7614fcd68decf9461b3b6290e95&lt;SEP&gt;chunk-a07cef05efd947a538701b4c41b162b1&lt;SEP&gt;chunk-fd4cfbed43aa26af0eef694fecac2177&lt;SEP&gt;chunk-e8e236a5eba0e1dbf843d32e509da045</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="ACE Inhibitors">
      <data key="d0">ACE Inhibitors</data>
      <data key="d1">content</data>
      <data key="d2">ACE inhibitors are a class of medications recommended for treating hypertension, particularly in patients with diabetes.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="ARBs">
      <data key="d0">ARBs</data>
      <data key="d1">content</data>
      <data key="d2">Angiotensin receptor blockers (ARBs) are used for hypertension management, especially in patients with diabetes and microalbuminuria.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="β-Blockers">
      <data key="d0">β-Blockers</data>
      <data key="d1">content</data>
      <data key="d2">β-blockers are medications beneficial for hypertension, particularly post-myocardial infarction in diabetic patients.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="Fasting">
      <data key="d0">Fasting</data>
      <data key="d1">concept</data>
      <data key="d2">Fasting is the practice of abstaining from food, which poses particular challenges for diabetes management.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="Primary Health Care Physician">
      <data key="d0">Primary Health Care Physician</data>
      <data key="d1">person</data>
      <data key="d2">Primary health care physicians play a critical role in the management and treatment of diabetes patients within a multidisciplinary clinic setting.</data>
      <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="Nephropathy">
      <data key="d0">Nephropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Nephropathy is a kidney condition that can arise as a complication from diabetes, characterized by damage that can lead to kidney failure.&lt;SEP&gt;Nephropathy refers to kidney-related complications that can arise in diabetic patients, potentially worsened by certain medical procedures involving radiopaque dye.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0&lt;SEP&gt;chunk-e8e236a5eba0e1dbf843d32e509da045&lt;SEP&gt;chunk-5e1400e1158e4f7be2283a0366ebf4f2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894211</data>
      <data key="d6" />
    </node>
    <node id="Foot Ulcers">
      <data key="d0">Foot Ulcers</data>
      <data key="d1">concept</data>
      <data key="d2">Foot ulcers are wounds or sores that develop on the feet, particularly in diabetic patients, requiring careful management and treatment.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Diabetes Care Team">
      <data key="d0">Diabetes Care Team</data>
      <data key="d1">concept</data>
      <data key="d2">The Diabetes Care Team is a group of health professionals, including physicians and nurses, dedicated to managing and treating diabetic patients, particularly for complications like foot issues.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Vascular Radiologist">
      <data key="d0">Vascular Radiologist</data>
      <data key="d1">person</data>
      <data key="d2">A vascular radiologist specializes in imaging techniques and minimally invasive procedures to treat vascular diseases, including non-invasive intra-arterial angioplasty for diabetic patients.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Vascular Surgeon">
      <data key="d0">Vascular Surgeon</data>
      <data key="d1">person</data>
      <data key="d2">A vascular surgeon performs surgeries to correct vascular problems, which may be necessary for diabetic patients with severe complications.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Orthopaedic Surgeon">
      <data key="d0">Orthopaedic Surgeon</data>
      <data key="d1">person</data>
      <data key="d2">An orthopaedic surgeon focuses on the musculoskeletal system, providing corrections for structural abnormalities in diabetic patients.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Physiotherapists">
      <data key="d0">Physiotherapists</data>
      <data key="d1">person</data>
      <data key="d2">Physiotherapists assist in rehabilitating diabetic patients, especially post-amputation, helping them regain mobility and function.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Health Professionals">
      <data key="d0">Health Professionals</data>
      <data key="d1">concept</data>
      <data key="d2">Health professionals are individuals trained to manage, prevent, and treat health conditions, including diabetes mellitus.&lt;SEP&gt;Health professionals encompass a broad category of individuals, including doctors and nurses, involved in the care and treatment of patients with diabetes and its complications.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0&lt;SEP&gt;chunk-85ef35aaa38ac4f0c032c8bc3f6df559</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Diabetic Foot Lesions">
      <data key="d0">Diabetic Foot Lesions</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetic foot lesions refer to the various types of injuries or sores that occur on the feet of diabetic patients due to nerve damage and poor circulation.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Primary Prevention">
      <data key="d0">Primary Prevention</data>
      <data key="d1">concept</data>
      <data key="d2">Primary prevention encompasses strategies aimed at preventing the onset of diseases like type 2 diabetes through lifestyle modifications and health education.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Tertiary Prevention">
      <data key="d0">Tertiary Prevention</data>
      <data key="d1">concept</data>
      <data key="d2">Tertiary prevention involves interventions designed to improve the quality of life for patients already diagnosed with chronic diseases, including managing complications of diabetes.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Randomized Controlled Trials">
      <data key="d0">Randomized Controlled Trials</data>
      <data key="d1">method</data>
      <data key="d2">Randomized controlled trials are research studies that randomly assign participants to different interventions to compare outcomes, often used to study diabetes prevention strategies.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894212</data>
      <data key="d6" />
    </node>
    <node id="Angiography">
      <data key="d0">Angiography</data>
      <data key="d1">method</data>
      <data key="d2">Angiography is a medical imaging technique used to visualize the blood vessels, its use may provoke renal deterioration in patients with nephropathy.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Plantar Supports">
      <data key="d0">Plantar Supports</data>
      <data key="d1">concept</data>
      <data key="d2">Plantar supports are devices used to alleviate pressure on the feet, often required for patients with resistant foot ulcers.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Education Programme">
      <data key="d0">Education Programme</data>
      <data key="d1">concept</data>
      <data key="d2">An education programme is designed to enhance the knowledge of diabetic patients at risk of developing foot ulcers.</data>
      <data key="d3">chunk-56d9ff3515afac60e7566e41837249a0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Diabetic Neuropathy">
      <data key="d0">Diabetic Neuropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetic neuropathy is a common microvascular complication of diabetes mellitus, characterized by nerve damage due to high blood sugar levels.&lt;SEP&gt;Diabetic neuropathy is a nerve disorder resulting from diabetes mellitus that can impact the peripheral and autonomic nervous systems.&lt;SEP&gt;Diabetic neuropathy is a complication of diabetes that affects the nerves and can lead to significant health issues, including foot problems and amputations.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7&lt;SEP&gt;chunk-fd4cfbed43aa26af0eef694fecac2177&lt;SEP&gt;chunk-55d2691a8c714949752d249721fec5e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Distal Symmetrical Sensory-Motor Polyneuropathy">
      <data key="d0">Distal Symmetrical Sensory-Motor Polyneuropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Distal symmetrical sensory-motor polyneuropathy is a form of neuropathy that presents in three stages: early, symptomatic, and severe, with varying symptoms.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Early Distal Sensory-Motor Neuropathy">
      <data key="d0">Early Distal Sensory-Motor Neuropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Early distal sensory-motor neuropathy is usually asymptomatic, but some sensory abnormalities can be detected through neuro-physiological testing.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Symptomatic Distal Sensory-Motor Neuropathy">
      <data key="d0">Symptomatic Distal Sensory-Motor Neuropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Symptomatic distal sensory-motor neuropathy is characterized by sensory loss and may include paraesthesia and pain.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Severe Distal Sensory-Motor Neuropathy">
      <data key="d0">Severe Distal Sensory-Motor Neuropathy</data>
      <data key="d1">concept</data>
      <data key="d2">Severe distal sensory-motor neuropathy exhibits motor involvement and may lead to significant disability, ulceration, and loss of limbs.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Hyperglycaemia">
      <data key="d0">Hyperglycaemia</data>
      <data key="d1">concept</data>
      <data key="d2">Hyperglycaemia refers to elevated blood glucose levels, which is a key feature in the management of individuals with metabolic syndrome.&lt;SEP&gt;Hyperglycaemia refers to elevated blood glucose levels, often associated with diabetes.&lt;SEP&gt;Hyperglycaemia refers to elevated blood sugar levels, which can promote atherosclerosis and other complications in diabetes.&lt;SEP&gt;Hyperglycaemia is a condition of elevated blood sugar levels linked to the pathophysiology of diabetic neuropathy.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7&lt;SEP&gt;chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe&lt;SEP&gt;chunk-12fe828372a20b6606e010f0fd5e6263&lt;SEP&gt;chunk-e8e236a5eba0e1dbf843d32e509da045</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894213</data>
      <data key="d6" />
    </node>
    <node id="Screening Strategies">
      <data key="d0">Screening Strategies</data>
      <data key="d1">concept</data>
      <data key="d2">Screening strategies involve various testing methods to detect cardiovascular autonomic neuropathy and distal sensory-motor neuropathy.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894214</data>
      <data key="d6" />
    </node>
    <node id="Aldose Reductase Inhibitors">
      <data key="d0">Aldose Reductase Inhibitors</data>
      <data key="d1">concept</data>
      <data key="d2">Aldose reductase inhibitors are medications that can inhibit the polyol pathway and are used to address diabetic neuropathy.&lt;SEP&gt;Aldose reductase inhibitors are therapeutic agents being investigated for their potential to address diabetic neuropathy.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7&lt;SEP&gt;chunk-55d2691a8c714949752d249721fec5e7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894214</data>
      <data key="d6" />
    </node>
    <node id="Patient Education">
      <data key="d0">Patient Education</data>
      <data key="d1">concept</data>
      <data key="d2">Patient education involves informing patients about risk factors, prevention, and management of diabetic neuropathy.&lt;SEP&gt;Patient education involves informing patients and physicians about diabetic neuropathy and care to prevent complications and improve outcomes.</data>
      <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7&lt;SEP&gt;chunk-55d2691a8c714949752d249721fec5e7</data>
      <data key="d4">unknown_source</data>
