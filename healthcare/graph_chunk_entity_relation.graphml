    <node id="Primary Care Physician">
      <data key="d0">Primary Care Physician</data>
      <data key="d1">person</data>
      <data key="d2">A primary care physician is a healthcare provider responsible for the initial screening and management of patients with diabetes-related eye issues.</data>
      <data key="d3">chunk-7ef79f22f40772c2060b439008ce485b</data>
      <data key="d4">unknown_source</data>
