    <node id="Trans-Fatty Acids">
      <data key="d0">Trans-Fatty Acids</data>
      <data key="d1">concept</data>
      <data key="d2">Trans-fatty acids raise plasma LDL cholesterol and lower HDL cholesterol, and their intake is recommended to be minimized.</data>
      <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
