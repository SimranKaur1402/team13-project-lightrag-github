      <data key="d0">Diabetes Mellitus - Management</data>
      <data key="d1">concept</data>
      <data key="d2">Diabetes Mellitus - Management encompasses the processes and approaches used to manage diabetes mellitus effectively.</data>
      <data key="d3">chunk-b253411e54c35aa95f5f9179723bba3b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894229</data>
