    <node id="Neurogenic Bladder">
      <data key="d0">Neurogenic Bladder</data>
      <data key="d1">concept</data>
      <data key="d2">Neurogenic bladder is a urinary condition often seen in diabetic patients that can lead to complications such as urinary tract infections.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
