    </node>
    <node id="Insulin Regimen">
      <data key="d0">Insulin Regimen</data>
      <data key="d1">method</data>
      <data key="d2">Insulin regimen refers to the planned administration of insulin for the management of diabetes.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
      <data key="d6" />
    </node>
    <node id="Population Screening">
      <data key="d0">Population Screening</data>
      <data key="d1">method</data>
      <data key="d2">Population screening is a health strategy aimed at identifying individuals with a specific disease in a defined group.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f</data>
