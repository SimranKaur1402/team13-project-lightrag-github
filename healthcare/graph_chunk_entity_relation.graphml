      <data key="d0">Tuberculosis</data>
      <data key="d1">disease</data>
      <data key="d2">Tuberculosis is a serious infection that can affect respiratory and other organ systems, posing significant health threats to individuals with diabetes.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894232</data>
      <data key="d6" />
    </node>
    <node id="Atherosclerosis">
      <data key="d0">Atherosclerosis</data>
      <data key="d1">concept</data>
      <data key="d2">Atherosclerosis is a common macrovascular complication of diabetes that significantly increases the risk of mortality in diabetic patients.</data>
      <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
      <data key="d4">unknown_source</data>
