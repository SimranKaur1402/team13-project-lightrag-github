    </node>
    <node id="Screening for Diabetes Mellitus">
      <data key="d0">Screening for Diabetes Mellitus</data>
      <data key="d1">concept</data>
      <data key="d2">Screening for diabetes mellitus discusses methods for detecting diabetes in individuals, emphasizing the need for early detection to prevent complications.&lt;SEP&gt;Screening for diabetes mellitus entails assessing individuals for risk factors using various diagnostic tests to detect diabetes symptoms early.</data>
      <data key="d3">chunk-1b7df1782c359efe079f6ade12b3688f&lt;SEP&gt;chunk-25fb88c8ed14936954356d104de095d4</data>
      <data key="d4">unknown_source</data>
