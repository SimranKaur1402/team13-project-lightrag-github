    <node id="Kidney Disease">
      <data key="d0">Kidney Disease</data>
      <data key="d1">concept</data>
      <data key="d2">Kidney disease refers to the detrimental alterations of kidney function often exacerbated by high blood pressure and diabetes.</data>
      <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894240</data>
