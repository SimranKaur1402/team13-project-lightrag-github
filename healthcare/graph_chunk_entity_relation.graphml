      <data key="d1">concept</data>
      <data key="d2">Diabetes Mellitus - Guidelines includes the recommendations and best practices for handling diabetes mellitus.</data>
      <data key="d3">chunk-b253411e54c35aa95f5f9179723bba3b</data>
