    <node id="Vector Toxicity">
      <data key="d0">Vector Toxicity</data>
      <data key="d1">concept</data>
      <data key="d2">Vector Toxicity is a specific condition mentioned in the context of diabetes types that may require insulin for survival in rare instances.</data>
      <data key="d3">chunk-92fbe09a650e62b7b6ea5d8769440e51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1768894231</data>
