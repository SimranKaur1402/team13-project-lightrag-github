    <node id="Energy Systems">
      <data key="d0">Energy Systems</data>
      <data key="d1">concept</data>
      <data key="d2">Energy systems are critical for modern economies, supporting various sectors such as industrial production, transportation, communication, and household activities.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
