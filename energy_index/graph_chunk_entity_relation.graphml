    </node>
    <node id="Wind Energy">
      <data key="d0">Wind Energy</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Wind energy is another renewable energy source that utilizes wind to generate electricity.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709048</data>
