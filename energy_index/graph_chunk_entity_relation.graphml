    <node id="Environmental Compliance">
      <data key="d0">Environmental Compliance</data>
      <data key="d1">concept</data>
      <data key="d2">Environmental compliance refers to the adherence to regulations that ensure reliable, affordable, and sustainable energy supply.</data>
      <data key="d3">chunk-ba30ff765cf7628b7d0bf16fe4039b48</data>
      <data key="d4">unknown_source</data>
