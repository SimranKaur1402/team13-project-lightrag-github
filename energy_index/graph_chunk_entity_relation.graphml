    <node id="Clean Energy Technologies">
      <data key="d0">Clean Energy Technologies</data>
      <data key="d1">concept</data>
      <data key="d2">Clean energy technologies refer to methods and tools designed to generate energy from renewable sources, contributing to sustainability and reducing environmental impacts.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
