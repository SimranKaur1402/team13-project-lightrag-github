    <node id="Hydroelectric Power">
      <data key="d0">Hydroelectric Power</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Hydroelectric power is generated by harnessing the energy of flowing water, contributing to renewable energy efforts.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
