    <node id="Energy Generation">
      <data key="d0">Energy Generation</data>
      <data key="d1">concept</data>
      <data key="d2">Energy generation refers to the process of producing energy from various sources, including fossil fuels, nuclear power, and renewable options.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709047</data>
      <data key="d6" />
    </node>
    <node id="Energy Distribution">
      <data key="d0">Energy Distribution</data>
      <data key="d1">concept</data>
      <data key="d2">Energy distribution involves the methods and infrastructure used to deliver produced energy to consumers and various sectors.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709047</data>
      <data key="d6" />
    </node>
    <node id="Energy Policy">
      <data key="d0">Energy Policy</data>
      <data key="d1">concept</data>
      <data key="d2">Energy policy governs the regulations surrounding energy pricing, market access, safety standards, and environmental compliance.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709047</data>
      <data key="d6" />
    </node>
    <node id="Sustainability Challenges">
      <data key="d0">Sustainability Challenges</data>
      <data key="d1">concept</data>
      <data key="d2">Sustainability challenges in energy systems relate to environmental impacts, resource depletion, and promoting sustainable practices.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709047</data>
      <data key="d6" />
    </node>
    <node id="Fossil Fuels">
      <data key="d0">Fossil Fuels</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Fossil fuels are traditional energy sources, such as coal, oil, and natural gas, with significant economic and environmental implications.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709047</data>
      <data key="d6" />
    </node>
    <node id="Nuclear Power">
      <data key="d0">Nuclear Power</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Nuclear power is an energy generation method that uses nuclear reactions to produce electricity.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709047</data>
      <data key="d6" />
    </node>
    <node id="Solar Energy">
      <data key="d0">Solar Energy</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Solar energy is a renewable energy source harnessed from sunlight and is key for sustainable energy transitions.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1767709047</data>
