    <node id="Carbon Pricing">
      <data key="d0">Carbon Pricing</data>
      <data key="d1">method</data>
      <data key="d2">Carbon pricing is a strategy aimed at reducing greenhouse gas emissions by assigning a cost to carbon output.</data>
      <data key="d3">chunk-0d92e720e7cfbfc2155b52aa88b0156f</data>
      <data key="d4">unknown_source</data>
