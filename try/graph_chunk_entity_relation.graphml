  <data key="d0">Early Distal Sensory-Motor Neuropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Early distal sensory-motor neuropathy is usually asymptomatic, but sensory abnormalities may be detected through neuro-physiological testing.</data>
  <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850016</data>
