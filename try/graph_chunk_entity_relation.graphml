<node id="Neuropathy">
  <data key="d0">Neuropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Neuropathy is a condition that affects the peripheral nervous system, leading to symptoms such as tingling and decreased sensation, particularly in diabetic patients.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850008</data>
  <data key="d6"></data>
</node>
<node id="Amputation">
  <data key="d0">Amputation</data>
  <data key="d1">event</data>
  <data key="d2">Amputation refers to the surgical removal of a limb or part of a limb, often associated with complications from diabetes.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850009</data>
  <data key="d6"></data>
</node>
<node id="Diabetic Foot">
  <data key="d0">Diabetic Foot</data>
  <data key="d1">concept</data>
  <data key="d2">Diabetic foot refers to foot problems in diabetic patients that can lead to serious consequences such as ulcers and potential amputations.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850009</data>
  <data key="d6"></data>
</node>
<node id="Economic Barriers">
  <data key="d0">Economic Barriers</data>
  <data key="d1">concept</data>
  <data key="d2">Economic barriers refer to the financial obstacles that prevent patients from seeking appropriate medical care.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850009</data>
  <data key="d6"></data>
</node>
<node id="Educational Programme">
  <data key="d0">Educational Programme</data>
  <data key="d1">method</data>
  <data key="d2">An educational programme aims to inform patients and physicians about the risks and management of diabetic neuropathy.&lt;SEP&gt;An educational programme is aimed at increasing the knowledge of diabetic patients regarding foot lesion prevention.</data>
  <data key="d3">chunk-55d2691a8c714949752d249721fec5e7&lt;SEP&gt;chunk-56d9ff3515afac60e7566e41837249a0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850009</data>
  <data key="d6"></data>
