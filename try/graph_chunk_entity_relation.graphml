  <data key="d0">Symptomatic Distal Sensory-Motor Neuropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Symptomatic distal sensory-motor neuropathy is marked by sensory loss, often accompanied by paraesthesia and pain.</data>
  <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850016</data>
  <data key="d6"></data>
</node>
