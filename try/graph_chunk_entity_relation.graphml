  <data key="d0">Multidisciplinary Mini Clinics</data>
  <data key="d1">concept</data>
  <data key="d2">Multidisciplinary mini clinics for diabetes care involve a team approach to improve clinical outcomes for diabetic patients.</data>
  <data key="d3">chunk-453e4228f98ddea76e07ce405d13fd32</data>
