  <data key="d0">Severe Distal Sensory-Motor Neuropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Severe distal sensory-motor neuropathy involves motor involvement and disabling symptoms, with risks of ulceration leading to infection and necrosis.</data>
  <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850016</data>
  <data key="d6"></data>
</node>
<node id="Cardiovascular Autonomic Neuropathy">
  <data key="d0">Cardiovascular Autonomic Neuropathy</data>
  <data key="d1">concept</data>
  <data key="d2">Cardiovascular autonomic neuropathy affects heart rate control and increases mortality risk during general anaesthesia.</data>
  <data key="d3">chunk-0748670b42b0f4e0b2ed9c5ce62d54e7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850016</data>
