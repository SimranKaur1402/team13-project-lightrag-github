  <data key="d0">Renal Replacement Therapy</data>
  <data key="d1">method</data>
  <data key="d2">Renal replacement therapy includes treatments like dialysis or transplantation for patients with end-stage kidney disease.</data>
  <data key="d3">chunk-fd4cfbed43aa26af0eef694fecac2177</data>
