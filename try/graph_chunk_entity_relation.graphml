  <data key="d1">concept</data>
  <data key="d2">Saturated fatty acids are a type of fat that, when compared to poly-unsaturated fatty acids, have specific effects on cholesterol levels in plasma.</data>
  <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850005</data>
