  <data key="d0">Mono-Unsaturated Fatty Acids</data>
  <data key="d1">concept</data>
  <data key="d2">Mono-unsaturated fatty acids are fats compared to poly-unsaturated fatty acids, which also help reduce total and LDL cholesterol.</data>
  <data key="d3">chunk-eb0252816f7fbee4c50f79ef3ee56063</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1769850005</data>
