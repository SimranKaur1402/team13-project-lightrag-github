  <data key="d6"></data>
</node>
<node id="Noncommunicable Diseases">
  <data key="d0">Noncommunicable Diseases</data>
  <data key="d1">concept</data>
  <data key="d2">Noncommunicable diseases are chronic diseases such as diabetes, heart disease, and hypertension that are typically preventable through lifestyle modifications.</data>
  <data key="d3">chunk-c4d75b2c01d2448f37de4deec12208fa</data>
