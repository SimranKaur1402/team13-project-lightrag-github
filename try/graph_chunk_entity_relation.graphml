  <data key="d0">Urinary Albumin Excretion</data>
  <data key="d1">data</data>
  <data key="d2">Urinary albumin excretion exceeding 30 mg/24 hours is a significant risk factor for macrovascular disease in people with diabetes.</data>
  <data key="d3">chunk-8e3bf51a75faa8eb6fe5fe7a0e509efe</data>
